#version 460
#extension GL_EXT_ray_query : require
#extension GL_EXT_scalar_block_layout : enable

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

const float RGB_CLAMP = 1.0;
const float PI = 3.14159265358979323846;
const float EPS = 1e-4;
const float INF_T = 1e30;
const float MEDIUM_EPS = 1e-4;

const float GLASS_MIN_TRANSMIT = 0.02;
const float MIN_T = 1e-3;

const float LAMBDA_MIN = 400.0;
const float LAMBDA_MAX = 700.0;
const float XYZ_NORMALIZE = 0.00936;

struct GpuPathState {
    vec4 ro;
    vec4 rd;

    // x = scalar spectral throughput
    // y = sampled wavelength in nm
    // z,w unused
    vec4 throughput_lambda;

    // xyz = accumulated XYZ radiance for this path
    vec4 radianceXYZ;

    uint pixelIndex;
    uint alive;
    uint bounce;
    uint pad0;
};

struct DielectricSample {
    vec3 dir;
    float f;
    float pdf;
    uint isTransmission;
    uint isDelta;
};

struct Material {
    vec4 albedo_smoothness;                              // xyz = albedo, w = smoothness
    vec4 emissive_emissiveIntensity;                    // xyz = emissiveColor, w = emissiveIntensity
    vec4 metallic_smoothShading_transmission_ior;       // x = metallic, y = smoothShading, z = transmission, w = ior
    vec4 dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta;
    vec4 thinFilmSubstrateK_absorption_pad;
};

struct EmissiveTriangle {
    uvec4 triIndex_pad;         // x = triIndex
    vec4 area_pmf_cdf_pad;      // x = area, y = pmf, z = cdf
};

struct TransmissiveTriangle {
    uvec4 triIndex_pad;
    vec4 area_pmf_cdf_pad; // x=area, y=weight/pdf-mass, z=cdf
};

layout(std140, binding = 0) uniform FrameParams {
    uvec4 screen;
    uvec4 extra;

    vec4 camPos;
    vec4 camForward;
    vec4 camRight;
    vec4 camUp;
    vec4 camData;

    vec4 sunDirIntensity;
    vec4 sunColor;
    vec4 fogParams;

    vec4 misc;
    vec4 misc2;
    uvec4 causticState;

    uvec4 transmissiveTriangleCount;

    vec4 whiteBalance;

    uint photonHitCapacity;
    uint photonPad0;
    uint photonPad1;
    uint photonPad2;
} frame;

layout(std430, binding = 1) buffer PathBuffer {
    GpuPathState paths[];
};

layout(binding = 2, rgba32f) uniform writeonly image2D outImage;
layout(binding = 3, rgba32f) uniform coherent image2D accumImage;
layout(binding = 4) uniform accelerationStructureEXT sceneTLAS;

layout(std430, binding = 5) readonly buffer VertexBuffer {
    float vertexData[];
};

layout(std430, binding = 6) readonly buffer IndexBuffer {
    uint indexData[];
};

layout(std430, binding = 7) readonly buffer TriangleMaterialBuffer {
    uint triangleMaterialIndices[];
};

layout(std430, binding = 8) readonly buffer MaterialBuffer {
    Material materials[];
};

layout(std430, binding = 9) readonly buffer EmissiveTriBuffer {
    EmissiveTriangle emissiveTriangles[];
};

layout(std430, binding = 10) readonly buffer NormalBuffer {
    float normalData[];
};

// Output textures for denoiser
layout(binding = 11, rgba32f) uniform writeonly image2D albedoImage;
layout(binding = 12, rgba32f) uniform writeonly image2D normalImage;
layout(binding = 13, rgba32f) uniform writeonly image2D depthImage;

