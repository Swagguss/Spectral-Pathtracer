vec3 sampleCausticsImageXYZ(ivec2 pix) {
    return max(imageLoad(causticsImage, pix).xyz, vec3(0.0));
}

uint sampleTransmissiveTriangle(float xi, uint count) {
    if (count == 0u) {
        return 0u;
    }

    xi = min(max(xi, 0.0), 0.99999994);

    uint lo = 0u;
    uint hi = count;

    while (lo < hi) {
        uint mid = lo + ((hi - lo) >> 1u);
        float cdf = transmissiveTriangles[mid].area_pmf_cdf_pad.z;

        if (xi <= cdf) {
            hi = mid;
        } else {
            lo = mid + 1u;
        }
    }

    return min(lo, count - 1u);
}

vec3 loadNormal(uint vertexIndex) {
    uint base = vertexIndex * 3u;
    return vec3(
        normalData[base + 0u],
        normalData[base + 1u],
        normalData[base + 2u]
    );
}

uint hash_u32(uint x) {
    x ^= x >> 16;
    x *= 0x7feb352du;
    x ^= x >> 15;
    x *= 0x846ca68bu;
    x ^= x >> 16;
    return x;
}

float rand01(inout uint state) {
    state = hash_u32(state);
    return float(state) * (1.0 / 4294967296.0);
}

vec3 clamp_rgb_luma(vec3 color, float maxLuma) {
    float luma = dot(color, vec3(0.2126, 0.7152, 0.0722));
    if (luma <= maxLuma || luma <= 1e-8) {
        return color;
    }
    return color * (maxLuma / luma);
}

float gauss1(float x, float mu, float sigma) {
    float t = (x - mu) / sigma;
    return exp(-0.5 * t * t);
}

float rgb_to_spectrum_unit(float lambda, vec3 rgb) {
    float Sr = exp(-((lambda - 610.0) / 35.0) * ((lambda - 610.0) / 35.0));
    float Sg = exp(-((lambda - 540.0) / 30.0) * ((lambda - 540.0) / 30.0));
    float Sb = exp(-((lambda - 460.0) / 20.0) * ((lambda - 460.0) / 20.0));

    float denom = max(Sr + Sg + Sb, 1e-6);
    vec3 c = max(rgb, vec3(0.0));
    return (c.r * Sr + c.g * Sg + c.b * Sb) / denom;
}

float rgb_to_reflectance_spectrum(float lambda, vec3 rgb) {
    vec3 c = clamp(rgb, vec3(0.0), vec3(1.0));
    float m = max(c.r, max(c.g, c.b));
    if (m <= 0.0) return 0.0;

    vec3 chroma = c / m;
    float s = rgb_to_spectrum_unit(lambda, chroma);
    return clamp(m * s, 0.0, 0.999);
}

float rgb_to_emission_spectrum(float lambda, vec3 rgb) {
    vec3 c = max(rgb, vec3(0.0));
    float m = max(c.r, max(c.g, c.b));
    if (m <= 0.0) return 0.0;

    vec3 chroma = c / m;
    float s = rgb_to_spectrum_unit(lambda, chroma);
    return m * s;
}

vec3 cie_xyz_bar(float lambda) {
    float x =
        1.056 * gauss1(lambda, 599.8, 37.9) +
        0.362 * gauss1(lambda, 442.0, 16.0) -
        0.065 * gauss1(lambda, 501.1, 20.4);

    float y =
        0.821 * gauss1(lambda, 568.8, 23.4) +
        0.286 * gauss1(lambda, 530.9, 32.3);

    float z =
        1.217 * gauss1(lambda, 437.0, 11.8) +
        0.681 * gauss1(lambda, 459.0, 26.0);

    return max(vec3(x, y, z), vec3(0.0)) * XYZ_NORMALIZE;
}

vec3 xyz_to_linear_srgb(vec3 xyz) {
    float r =  3.2406 * xyz.x - 1.5372 * xyz.y - 0.4986 * xyz.z;
    float g = -0.9689 * xyz.x + 1.8758 * xyz.y + 0.0415 * xyz.z;
    float b =  0.0557 * xyz.x - 0.2040 * xyz.y + 1.0570 * xyz.z;
    return vec3(r, g, b);
}

vec3 linear_srgb_to_xyz(vec3 rgb) {
    float x = 0.4124 * rgb.r + 0.3576 * rgb.g + 0.1805 * rgb.b;
    float y = 0.2126 * rgb.r + 0.7152 * rgb.g + 0.0722 * rgb.b;
    float z = 0.0193 * rgb.r + 0.1192 * rgb.g + 0.9505 * rgb.b;
    return vec3(x, y, z);
}

vec3 orthonormalT(vec3 N) {
    return normalize(abs(N.z) < 0.999
        ? cross(N, vec3(0.0, 0.0, 1.0))
        : cross(N, vec3(0.0, 1.0, 0.0)));
}

bool pointToTriangleBary(
    vec3 p, vec3 a, vec3 b, vec3 c,
    out vec3 bc
) {
    vec3 v0 = b - a;
    vec3 v1 = c - a;
    vec3 v2 = p - a;

    float d00 = dot(v0, v0);
    float d01 = dot(v0, v1);
    float d11 = dot(v1, v1);
    float d20 = dot(v2, v0);
    float d21 = dot(v2, v1);

    float denom = d00 * d11 - d01 * d01;
    if (abs(denom) < 1e-12) {
        bc = vec3(1.0, 0.0, 0.0);
        return false;
    }

    float v = (d11 * d20 - d01 * d21) / denom;
    float w = (d00 * d21 - d01 * d20) / denom;
    float u = 1.0 - v - w;

    bc = vec3(u, v, w);
    return true;
}

vec3 baryToPoint(vec3 bc, vec3 a, vec3 b, vec3 c) {
    return bc.x * a + bc.y * b + bc.z * c;
}

float randn(inout uint rng) {
    float u1 = max(rand01(rng), 1e-8);
    float u2 = rand01(rng);
    return sqrt(-2.0 * log(u1)) * cos(2.0 * PI * u2);
}

bool sampleTriangleGuidedBary(
    vec3 bcCenter,
    float sigma,
    inout uint rng,
    out vec3 bc,
    out float pdfLocal
) {
    for (int attempt = 0; attempt < 8; ++attempt) {
        float dv = randn(rng) * sigma;
        float dw = randn(rng) * sigma;

        float v = bcCenter.y + dv;
        float w = bcCenter.z + dw;
        float u = 1.0 - v - w;

        if (u >= 0.0 && v >= 0.0 && w >= 0.0) {
            bc = vec3(u, v, w);

            float g = exp(-0.5 * (dv * dv + dw * dw) / max(sigma * sigma, 1e-8));
            pdfLocal = g / max(2.0 * PI * sigma * sigma, 1e-8);
            return true;
        }
    }

    bc = bcCenter;
    pdfLocal = 1.0 / max(2.0 * PI * sigma * sigma, 1e-8);
    return all(greaterThanEqual(bcCenter, vec3(0.0)));
}

void makeBasis(vec3 N, out vec3 T, out vec3 B) {
    T = orthonormalT(N);
    B = cross(T, N);
}

float phaseHG(float cosTheta, float g) {
    float g2 = g * g;
    float denom = 1.0 + g2 - 2.0 * g * cosTheta;
    return (1.0 - g2) / max(4.0 * PI * denom * sqrt(denom), 1e-8);
}

float phaseHGPdf(float cosTheta, float g) {
    return phaseHG(cosTheta, g);
}

vec3 samplePhaseHG(vec3 wo, float g, vec2 u, out float pdf) {
    float cosTheta;
    if (abs(g) < 1e-3) {
        cosTheta = 1.0 - 2.0 * u.x;
    } else {
        float sqr = (1.0 - g * g) / (1.0 - g + 2.0 * g * u.x);
        cosTheta = (1.0 + g * g - sqr * sqr) / (2.0 * g);
        cosTheta = clamp(cosTheta, -1.0, 1.0);
    }

    float sinTheta = sqrt(max(0.0, 1.0 - cosTheta * cosTheta));
    float phi = 2.0 * PI * u.y;

    vec3 w = normalize(-wo);
    vec3 T, B;
    makeBasis(w, T, B);

    vec3 wi = normalize(
        T * (cos(phi) * sinTheta) +
        B * (sin(phi) * sinTheta) +
        w * cosTheta
    );

    pdf = phaseHGPdf(dot(w, wi), g);
    return wi;
}

float sampleFreeFlight(float sigmaT, inout uint rng) {
    float u = max(1e-8, 1.0 - rand01(rng));
    return -log(u) / max(sigmaT, 1e-8);
}

float materialAbsorptionSigma(uint prim, float lambda) {
    Material mat = materials[triangleMaterialIndices[prim]];
    float tint = clamp(rgb_to_reflectance_spectrum(lambda, mat.albedo_smoothness.xyz), MIN_T, 0.9999);
    float strength = max(mat.thinFilmSubstrateK_absorption_pad.y, 0.0);
    return -log(tint) * strength;
}

float transmittanceHomogeneous(float sigmaT, float dist) {
    return exp(-sigmaT * max(dist, 0.0));
}

bool traceAnyHit(
    vec3 ro,
    vec3 rd,
    float tMax
) {
    rayQueryEXT rq;
    rayQueryInitializeEXT(
        rq,
        sceneTLAS,
        gl_RayFlagsOpaqueEXT,
        0xFF,
        ro,
        EPS,
        rd,
        tMax
    );

    while (rayQueryProceedEXT(rq)) {
    }

    return rayQueryGetIntersectionTypeEXT(rq, true) != gl_RayQueryCommittedIntersectionNoneEXT;
}

float iorAtLambda(float iorD, float dispersionStrength, float lambdaNm) {
    float lambda = lambdaNm * 1e-3; // um
    float V = mix(80.0, 10.0, clamp(dispersionStrength, 0.0, 1.0));

    float lambdaD = 0.5876;
    float lambdaF = 0.4861;
    float lambdaC = 0.6563;

    float dN = (iorD - 1.0) / V;
    float denom = (1.0 / (lambdaF * lambdaF)) - (1.0 / (lambdaC * lambdaC));
    float B = dN / denom;
    float A = iorD - B / (lambdaD * lambdaD);

    return A + B / (lambda * lambda);
}

float materialIorAtLambda(uint triIndex, float lambda) {
    Material mat = materials[triangleMaterialIndices[triIndex]];
    return iorAtLambda(mat.metallic_smoothShading_transmission_ior.w, mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.x, lambda);
}

vec3 loadVertex(uint vertexIndex) {
    uint base = vertexIndex * 3u;
    return vec3(
        vertexData[base + 0u],
        vertexData[base + 1u],
        vertexData[base + 2u]
    );
}

void loadTriangle(uint triIndex, out vec3 v0, out vec3 v1, out vec3 v2) {
    uint i0 = indexData[triIndex * 3u + 0u];
    uint i1 = indexData[triIndex * 3u + 1u];
    uint i2 = indexData[triIndex * 3u + 2u];
    v0 = loadVertex(i0);
    v1 = loadVertex(i1);
    v2 = loadVertex(i2);
}

vec3 triangleNormal(vec3 v0, vec3 v1, vec3 v2) {
    return normalize(cross(v1 - v0, v2 - v0));
}

vec2 sampleUniformTriangle(vec2 u) {
    float su0 = sqrt(u.x);
    return vec2(1.0 - su0, u.y * su0);
}

uint sampleEmissiveTriangle(float xi) {
    uint count = frame.extra.x;
    for (uint i = 0u; i < count; ++i) {
        if (xi <= emissiveTriangles[i].area_pmf_cdf_pad.z) {
            return i;
        }
    }
    return count - 1u;
}

bool traceClosest(
    vec3 ro,
    vec3 rd,
    out uint outPrim,
    out float outTHit,
    out vec2 outBary
) {
    rayQueryEXT rq;
    rayQueryInitializeEXT(
        rq,
        sceneTLAS,
        gl_RayFlagsOpaqueEXT,
        0xFF,
        ro,
        EPS,
        rd,
        INF_T
    );

    while (rayQueryProceedEXT(rq)) {
    }

    if (rayQueryGetIntersectionTypeEXT(rq, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
        return false;
    }

    vec2 bary = rayQueryGetIntersectionBarycentricsEXT(rq, true);

    outPrim = rayQueryGetIntersectionPrimitiveIndexEXT(rq, true);
    outTHit = rayQueryGetIntersectionTEXT(rq, true);
    outBary = rayQueryGetIntersectionBarycentricsEXT(rq, true);
    return true;
}

bool traceShadow(
    vec3 ro,
    vec3 rd,
    float tMax,
    uint lightTriIndex
) {
    rayQueryEXT rq;
    rayQueryInitializeEXT(
        rq,
        sceneTLAS,
        gl_RayFlagsOpaqueEXT,
        0xFF,
        ro,
        EPS,
        rd,
        tMax
    );

    while (rayQueryProceedEXT(rq)) {
    }

    if (rayQueryGetIntersectionTypeEXT(rq, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
        return false;
    }

    uint hitPrim = rayQueryGetIntersectionPrimitiveIndexEXT(rq, true);
    float hitT   = rayQueryGetIntersectionTEXT(rq, true);

    // If the first hit is the sampled light itself, treat it as visible.
    if (hitPrim == lightTriIndex && hitT <= tMax + 1e-3) {
        return false;
    }

    return true;
}

float saturate(float x) {
    return clamp(x, 0.0, 1.0);
}

float luminance(vec3 c) {
    return dot(c, vec3(0.2126, 0.7152, 0.0722));
}

float roughnessFromSmoothness(float smoothness) {
    return max(0.02, 1.0 - clamp(smoothness, 0.0, 1.0));
}

float alphaFromSmoothness(float smoothness) {
    float r = roughnessFromSmoothness(smoothness);
    return max(0.001, r * r);
}

bool isDeltaSpecular(float smoothness) {
    return smoothness > 0.98;
}

bool isOpaqueDeltaSpecular(float transmission, float metallic, float smoothness) {
    return transmission <= 0.001 && metallic > 0.999 && smoothness > 0.98;
}

float fresnelSchlickScalar(float cosTheta, float F0) {
    float m = 1.0 - saturate(cosTheta);
    float m2 = m * m;
    float m5 = m2 * m2 * m;
    return F0 + (1.0 - F0) * m5;
}

float D_GGX(float NoH, float alpha) {
    float alpha2 = alpha * alpha;
    float denom = NoH * NoH * (alpha2 - 1.0) + 1.0;
    return alpha2 / max(PI * denom * denom, 1e-8);
}

float G1_SmithGGX(float NoV, float alpha) {
    float a2 = alpha * alpha;
    float denom = NoV + sqrt(a2 + (1.0 - a2) * NoV * NoV);
    return (2.0 * NoV) / max(denom, 1e-8);
}

float G_SmithGGX(float NoV, float NoL, float alpha) {
    return G1_SmithGGX(NoV, alpha) * G1_SmithGGX(NoL, alpha);
}

vec3 sampleCosineHemisphere(vec3 N, vec2 u) {
    float phi = 2.0 * PI * u.x;
    float r = sqrt(u.y);
    float x = r * cos(phi);
    float y = r * sin(phi);
    float z = sqrt(max(0.0, 1.0 - u.y));

    vec3 T = normalize(abs(N.z) < 0.999 ? cross(N, vec3(0.0, 0.0, 1.0))
                                        : cross(N, vec3(0.0, 1.0, 0.0)));
    vec3 B = cross(T, N);

    return normalize(T * x + B * y + N * z);
}

float mediumSunDirect(
    vec3 x,
    vec3 wo,
    float lambda,
    float sigmaT,
    float g
) {
    if (frame.extra.y == 0u) return 0.0;

    vec3 sunDir = normalize(frame.sunDirIntensity.xyz);
    vec3 L = sunDir;

    float phaseVal = phaseHG(dot(wo, L), g);
    float pdfPhase = phaseHGPdf(dot(wo, L), g);

    if (phaseVal <= 0.0 || pdfPhase <= 0.0) return 0.0;

    bool occluded = traceAnyHit(x + L * MEDIUM_EPS, L, INF_T);
    if (occluded) return 0.0;

    float LeS = rgb_to_emission_spectrum(lambda, frame.sunColor.xyz * frame.sunDirIntensity.w);

    // Delta directional light: only NEE can sample it, so MIS weight = 1.
    float Tr = 1.0; // no finite distance, no medium extinction to infinity in this simple version
    return LeS * phaseVal * Tr;
}

float mediumAreaLightDirect(
    vec3 x,
    vec3 wo,
    float lambda,
    float sigmaT,
    float g,
    inout uint rng
) {
    if (frame.extra.x == 0u) return 0.0;

    uint lightSlot = sampleEmissiveTriangle(rand01(rng));
    uint lightTriIndex = emissiveTriangles[lightSlot].triIndex_pad.x;
    float lightArea = emissiveTriangles[lightSlot].area_pmf_cdf_pad.x;
    float lightPmf = emissiveTriangles[lightSlot].area_pmf_cdf_pad.y;

    if (lightArea <= 0.0 || lightPmf <= 0.0) return 0.0;

    vec3 lv0, lv1, lv2;
    loadTriangle(lightTriIndex, lv0, lv1, lv2);

    vec2 u = vec2(rand01(rng), rand01(rng));
    vec2 b = sampleUniformTriangle(u);
    float w0 = 1.0 - b.x - b.y;
    float w1 = b.x;
    float w2 = b.y;

    vec3 lightPos = w0 * lv0 + w1 * lv1 + w2 * lv2;
    vec3 lightN = triangleNormal(lv0, lv1, lv2);

    uint lightMatIndex = triangleMaterialIndices[lightTriIndex];
    Material lightMat = materials[lightMatIndex];
    vec3 Le = lightMat.emissive_emissiveIntensity.xyz * lightMat.emissive_emissiveIntensity.w;

    vec3 toLight = lightPos - x;
    float dist2 = dot(toLight, toLight);
    if (dist2 <= 1e-12) return 0.0;

    float dist = sqrt(dist2);
    vec3 L = toLight / dist;

    float cosLight = max(dot(lightN, -L), 0.0);
    if (cosLight <= 1e-8) return 0.0;

    bool occluded = traceShadow(x + L * MEDIUM_EPS, L, dist, lightTriIndex);
    if (occluded) return 0.0;

    float Tr = transmittanceHomogeneous(sigmaT, dist);

    float LeS = rgb_to_emission_spectrum(lambda, Le);
    float phaseVal = phaseHG(dot(wo, L), g);
    float pdfPhase = phaseHGPdf(dot(wo, L), g);

    float pdfLightArea = lightPmf / lightArea;
    float pdfLightW = pdfLightArea * dist2 / max(cosLight, 1e-8);

    float wLight = pdfLightW / max(pdfLightW + pdfPhase, 1e-8);

    return LeS * Tr * phaseVal * wLight / max(pdfLightW, 1e-8);
}

bool getEmissiveTriangleInfo(
    uint triIndex,
    out float outArea,
    out float outPmf
) {
    outArea = 0.0;
    outPmf = 0.0;

    for (uint i = 0u; i < frame.extra.x; ++i) {
        if (emissiveTriangles[i].triIndex_pad.x == triIndex) {
            outArea = emissiveTriangles[i].area_pmf_cdf_pad.x;
            outPmf  = emissiveTriangles[i].area_pmf_cdf_pad.y;
            return true;
        }
    }
    return false;
}

float mediumPhaseHitEmitter(
    vec3 scatterPos,
    vec3 wo,
    vec3 wi,
    uint hitPrim,
    float tHit,
    float lambda,
    float sigmaT,
    float g
) {
    uint matIndex = triangleMaterialIndices[hitPrim];
    Material mat = materials[matIndex];
    vec3 emissive = mat.emissive_emissiveIntensity.xyz * mat.emissive_emissiveIntensity.w;

    if (max(emissive.r, max(emissive.g, emissive.b)) <= 0.0) {
        return 0.0;
    }

    float lightArea, lightPmf;
    if (!getEmissiveTriangleInfo(hitPrim, lightArea, lightPmf)) {
        return 0.0;
    }
    if (lightArea <= 0.0 || lightPmf <= 0.0) {
        return 0.0;
    }

    vec3 v0, v1, v2;
    loadTriangle(hitPrim, v0, v1, v2);
    vec3 lightN = triangleNormal(v0, v1, v2);

    float cosLight = max(dot(lightN, -wi), 0.0);
    if (cosLight <= 1e-8) return 0.0;

    float dist2 = tHit * tHit;
    float pdfLightArea = lightPmf / lightArea;
    float pdfLightW = pdfLightArea * dist2 / max(cosLight, 1e-8);

    float pdfPhase = phaseHGPdf(dot(wo, wi), g);
    float wPhase = pdfPhase / max(pdfPhase + pdfLightW, 1e-8);

    float LeS = rgb_to_emission_spectrum(lambda, emissive);
    float Tr = transmittanceHomogeneous(sigmaT, tHit);

    return LeS * Tr * wPhase;
}

vec3 sampleGGXHalfVector(vec3 N, float alpha, vec2 u) {
    float alpha2 = alpha * alpha;

    float phi = 2.0 * PI * u.x;
    float cosTheta = sqrt((1.0 - u.y) / (1.0 + (alpha2 - 1.0) * u.y));
    float sinTheta = sqrt(max(0.0, 1.0 - cosTheta * cosTheta));

    vec3 T, B;
    makeBasis(N, T, B);

    return normalize(
        T * (cos(phi) * sinTheta) +
        B * (sin(phi) * sinTheta) +
        N * cosTheta
    );
}

vec3 sampleGGX(vec3 N, vec3 V, float smoothness, vec2 u) {
    float alpha = alphaFromSmoothness(smoothness);
    vec3 H = sampleGGXHalfVector(N, alpha, u);

    if (dot(V, H) <= 0.0) {
        return vec3(0.0);
    }

    vec3 L = reflect(-V, H);

    if (dot(N, L) <= 0.0) {
        return vec3(0.0);
    }

    return normalize(L);
}

float pdfDiffuse(vec3 N, vec3 L) {
    float NoL = saturate(dot(N, L));
    return NoL / PI;
}

float pdfGGXReflection(
    vec3 N,
    vec3 V,
    vec3 L,
    float smoothness
) {
    float NoV = saturate(dot(N, V));
    float NoL = saturate(dot(N, L));
    if (NoV <= 0.0 || NoL <= 0.0) return 0.0;

    vec3 H = normalize(V + L);
    float NoH = saturate(dot(N, H));
    float VoH = saturate(dot(V, H));
    if (VoH <= 0.0) return 0.0;

    float roughness = roughnessFromSmoothness(smoothness);
    float alpha = roughness * roughness;

    float D = D_GGX(NoH, alpha);

    // half-vector pdf converted to outgoing-direction pdf
    float pdfH = D * NoH;
    float pdfL = pdfH / max(4.0 * VoH, 1e-8);
    return pdfL;
}

float lightPdfSolidAngleFromPrevVertex(
    vec3 prevPos,
    vec3 prevGeomN,
    vec3 dir,
    uint hitTriIndex
) {
    float lightArea, lightPmf;
    if (!getEmissiveTriangleInfo(hitTriIndex, lightArea, lightPmf)) {
        return 0.0;
    }

    if (lightArea <= 0.0 || lightPmf <= 0.0) {
        return 0.0;
    }

    vec3 lv0, lv1, lv2;
    loadTriangle(hitTriIndex, lv0, lv1, lv2);
    vec3 lightN = triangleNormal(lv0, lv1, lv2);

    uint prim;
    float tHit;
    vec2 bary;
    if (!traceClosest(prevPos + prevGeomN * EPS, dir, prim, tHit, bary)) {
        return 0.0;
    }

    if (prim != hitTriIndex) {
        return 0.0;
    }

    vec3 hitPos = prevPos + dir * tHit;
    float dist2 = dot(hitPos - prevPos, hitPos - prevPos);
    if (dist2 <= 1e-12) {
        return 0.0;
    }

    float cosLight = max(dot(lightN, -dir), 0.0);
    if (cosLight <= 1e-8) {
        return 0.0;
    }

    float pdfArea = lightPmf / lightArea;
    return pdfArea * dist2 / max(cosLight, 1e-8);
}

float specularSamplingWeight(vec3 F0) {
    return clamp(luminance(F0), 0.05, 0.95);
}

float fresnelDielectric(float cosThetaI, float etaI, float etaT) {
    if (abs(etaI - etaT) < 1e-4) {
        return 0.0;
    }

    cosThetaI = clamp(cosThetaI, -1.0, 1.0);

    float sinThetaI = sqrt(max(0.0, 1.0 - cosThetaI * cosThetaI));
    float sinThetaT = (etaI / etaT) * sinThetaI;

    if (sinThetaT >= 1.0) {
        return 1.0;
    }

    float cosThetaT = sqrt(max(0.0, 1.0 - sinThetaT * sinThetaT));

    float rParl = ((etaT * cosThetaI) - (etaI * cosThetaT)) /
                  ((etaT * cosThetaI) + (etaI * cosThetaT));
    float rPerp = ((etaI * cosThetaI) - (etaT * cosThetaT)) /
                  ((etaI * cosThetaI) + (etaT * cosThetaT));

    return 0.5 * (rParl * rParl + rPerp * rPerp);
}

vec2 c_make(float re, float im) {
    return vec2(re, im);
}

vec2 c_conj(vec2 z) {
    return vec2(z.x, -z.y);
}

vec2 c_add(vec2 a, vec2 b) {
    return a + b;
}

vec2 c_sub(vec2 a, vec2 b) {
    return a - b;
}

vec2 c_mul(vec2 a, vec2 b) {
    return vec2(
        a.x * b.x - a.y * b.y,
        a.x * b.y + a.y * b.x
    );
}

vec2 c_scale(vec2 a, float s) {
    return a * s;
}

vec2 c_div(vec2 a, vec2 b) {
    float d = dot(b, b);
    if (d <= 1e-20) return vec2(0.0);
    return vec2(
        (a.x * b.x + a.y * b.y) / d,
        (a.y * b.x - a.x * b.y) / d
    );
}

float c_abs2(vec2 z) {
    return dot(z, z);
}

vec2 c_sqrt(vec2 z) {
    float r = length(z);
    float t = sqrt(max(0.0, 0.5 * (r + z.x)));
    float u = sqrt(max(0.0, 0.5 * (r - z.x)));
    float im = (z.y < 0.0) ? -u : u;
    vec2 outZ = vec2(t, im);

    // Pick the physically sensible branch more consistently.
    if (outZ.x < 0.0) outZ = -outZ;
    if (abs(outZ.x) < 1e-8 && outZ.y < 0.0) outZ = -outZ;
    return outZ;
}

vec2 c_exp_i(float phi) {
    return vec2(cos(phi), sin(phi));
}

vec2 complexCosThetaT(vec2 nI, vec2 nT, float sin2ThetaI) {
    vec2 ratio = c_div(nI, nT);
    vec2 ratio2 = c_mul(ratio, ratio);
    vec2 arg = c_sub(vec2(1.0, 0.0), c_scale(ratio2, sin2ThetaI));
    return c_sqrt(arg);
}

vec2 fresnelAmplitude_s(vec2 nI, vec2 nT, vec2 cosI, vec2 cosT) {
    vec2 num = c_sub(c_mul(nI, cosI), c_mul(nT, cosT));
    vec2 den = c_add(c_mul(nI, cosI), c_mul(nT, cosT));
    return c_div(num, den);
}

vec2 fresnelAmplitude_p(vec2 nI, vec2 nT, vec2 cosI, vec2 cosT) {
    vec2 num = c_sub(c_mul(nT, cosI), c_mul(nI, cosT));
    vec2 den = c_add(c_mul(nT, cosI), c_mul(nI, cosT));
    return c_div(num, den);
}

float thinFilmReflectanceOpaque(Material mat, float lambdaNm, float cosThetaI) {
    float thicknessNm = max(mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.y, 0.0);
    float filmIor     = max(mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.z, 1.0);
    float subEta      = max(mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.w, 1e-4);
    float subK        = max(mat.thinFilmSubstrateK_absorption_pad.x, 0.0);

    cosThetaI = clamp(cosThetaI, 0.0, 1.0);

    vec2 n0 = vec2(1.0, 0.0);
    vec2 n1 = vec2(filmIor, 0.0);
    vec2 n2 = vec2(subEta, subK);

    float sin2ThetaI = max(0.0, 1.0 - cosThetaI * cosThetaI);

    vec2 cos0 = vec2(cosThetaI, 0.0);
    vec2 cos1 = complexCosThetaT(n0, n1, sin2ThetaI);
    vec2 cos2 = complexCosThetaT(n0, n2, sin2ThetaI);

    vec2 r01s = fresnelAmplitude_s(n0, n1, cos0, cos1);
    vec2 r01p = fresnelAmplitude_p(n0, n1, cos0, cos1);

    vec2 r12s = fresnelAmplitude_s(n1, n2, cos1, cos2);
    vec2 r12p = fresnelAmplitude_p(n1, n2, cos1, cos2);

    // Film phase: beta = 2*pi/lambda * n1 * d * cos(theta1)
    // Since n1 is real here, beta is real.
    float beta = (2.0 * PI * filmIor * thicknessNm * cos1.x) / max(lambdaNm, 1e-6);
    vec2 e2ib = c_exp_i(2.0 * beta);

    vec2 rs_num = c_add(r01s, c_mul(r12s, e2ib));
    vec2 rs_den = c_add(vec2(1.0, 0.0), c_mul(c_mul(r01s, r12s), e2ib));
    vec2 rp_num = c_add(r01p, c_mul(r12p, e2ib));
    vec2 rp_den = c_add(vec2(1.0, 0.0), c_mul(c_mul(r01p, r12p), e2ib));

    vec2 rs = c_div(rs_num, rs_den);
    vec2 rp = c_div(rp_num, rp_den);

    float Rs = c_abs2(rs);
    float Rp = c_abs2(rp);

    return clamp(0.5 * (Rs + Rp), 0.0, 1.0);
}

float fresnelConductor(float cosThetaI, float eta, float k) {
    cosThetaI = clamp(cosThetaI, 0.0, 1.0);

    float cos2 = cosThetaI * cosThetaI;
    float sin2 = max(1.0 - cos2, 0.0);

    float eta2 = eta * eta;
    float k2   = k * k;

    float t0 = eta2 - k2 - sin2;
    float a2pb2 = sqrt(max(t0 * t0 + 4.0 * eta2 * k2, 0.0));
    float a = sqrt(max(0.5 * (a2pb2 + t0), 0.0));

    float t1 = a2pb2 + cos2;
    float t2 = 2.0 * a * cosThetaI;
    float Rs = (t1 - t2) / max(t1 + t2, 1e-8);

    float t3 = cos2 * a2pb2 + sin2 * sin2;
    float t4 = t2 * sin2;
    float Rp = Rs * (t3 - t4) / max(t3 + t4, 1e-8);

    return clamp(0.5 * (Rs + Rp), 0.0, 1.0);
}

float thinFilmReflectance(
    float cosTheta,
    float lambdaNm,
    float baseF,
    Material mat
) {
    float thicknessNm = max(mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.y, 0.0);
    float nFilm       = max(mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.z, 1.0);
    float etaSub      = max(mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.w, 1e-4);
    float kSub        = max(mat.thinFilmSubstrateK_absorption_pad.x, 0.0);

    if (thicknessNm <= 0.0 || nFilm <= 1.0001) {
        return clamp(baseF, 0.0, 1.0);
    }

    cosTheta = clamp(cosTheta, 0.0, 1.0);

    // Air -> film Snell
    float sin2Theta = max(1.0 - cosTheta * cosTheta, 0.0);
    float sin2Film = sin2Theta / max(nFilm * nFilm, 1e-8);

    if (sin2Film >= 1.0) {
        return 1.0;
    }

    float cosThetaFilm = sqrt(max(1.0 - sin2Film, 0.0));

    float R01 = fresnelDielectric(cosTheta, 1.0, nFilm);

    float etaRel = etaSub / nFilm;
    float kRel   = kSub / nFilm;
    float R12 = fresnelConductor(cosThetaFilm, etaRel, kRel);

    float phase = 4.0 * PI * nFilm * thicknessNm * cosThetaFilm / max(lambdaNm, 1e-3);
    float c = cos(phase);

    // Scalar Airy-style interference.
    float sqrtTerm = sqrt(max(R01 * R12, 0.0));
    float num = R01 + R12 + 2.0 * sqrtTerm * c;
    float den = 1.0 + R01 * R12 + 2.0 * sqrtTerm * c;

    return clamp(num / max(den, 1e-6), 0.0, 1.0);
}

float opaqueSpecularSamplingWeight(
    float albedoS,
    float metallic,
    float lambda,
    Material mat
) {
    float baseF0 = mix(0.04, albedoS, metallic);
    float coatedF0 = thinFilmReflectance(1.0, lambda, baseF0, mat);
    return clamp(coatedF0, 0.05, 0.95);
}

bool refractDir(vec3 I, vec3 N, float eta, out vec3 T) {
    // I points in ray direction (away from origin)
    float cosNI = dot(N, I);
    float k = 1.0 - eta * eta * (1.0 - cosNI * cosNI);
    if (k < 0.0) {
        return false;
    }

    T = normalize(eta * I - (eta * cosNI + sqrt(k)) * N);
    return true;
}

float bsdfPdf(
    vec3 N,
    vec3 V,
    vec3 L,
    float albedoS,
    float smoothness,
    float metallic,
    float lambda,
    Material mat
) {
    float specW = opaqueSpecularSamplingWeight(albedoS, metallic, lambda, mat);
    float diffW = 1.0 - specW;

    float pdfD = pdfDiffuse(N, L);
    float pdfS = pdfGGXReflection(N, V, L, smoothness);

    return diffW * pdfD + specW * pdfS;
}

vec3 sampleBSDF(
    vec3 N,
    vec3 V,
    float albedoS,
    float smoothness,
    float metallic,
    float lambda,
    Material mat,
    vec2 uSelect,
    vec2 uDir,
    out float outPdf
) {
    float specW = opaqueSpecularSamplingWeight(albedoS, metallic, lambda, mat);
    float diffW = 1.0 - specW;

    vec3 L;
    if (uSelect.x < diffW) {
        L = sampleCosineHemisphere(N, uDir);
    } else {
        L = sampleGGX(N, V, smoothness, uDir);
    }

    outPdf = bsdfPdf(N, V, L, albedoS, smoothness, metallic, lambda, mat);
    return L;
}

float evalDielectricMicrofacet(
    vec3 N,
    vec3 V,
    vec3 L,
    float roughness,
    float etaI,
    float etaT,
    out bool isTransmission
) {
    float NoV = dot(N, V);
    float NoL = dot(N, L);

    if (abs(NoV) < 1e-6 || abs(NoL) < 1e-6) {
        isTransmission = false;
        return 0.0;
    }

    bool reflectMode = (NoV * NoL > 0.0);
    isTransmission = !reflectMode;

    float alpha = max(0.001, roughness * roughness);

    if (reflectMode) {
        vec3 H = normalize(V + L);
        if (dot(H, N) < 0.0) H = -H;

        float NoH = saturate(dot(N, H));
        float VoH = saturate(dot(V, H));
        if (VoH <= 1e-8) return 0.0;

        float F = fresnelDielectric(VoH, etaI, etaT);
        float D = D_GGX(NoH, alpha);
        float G = G_SmithGGX(abs(NoV), abs(NoL), alpha);

        return F * D * G / max(4.0 * abs(NoV) * abs(NoL), 1e-8);
    } else {
        vec3 Hraw = -(etaI * V + etaT * L);
        float h2 = dot(Hraw, Hraw);
        if (h2 <= 1e-12) return 0.0;

        vec3 H = Hraw * inversesqrt(h2);
        if (dot(H, N) < 0.0) H = -H;

        float NoH = saturate(dot(N, H));
        float VoH = abs(dot(V, H));
        float LoH = abs(dot(L, H));

        if (VoH <= 1e-8 || LoH <= 1e-8) return 0.0;

        float F = fresnelDielectric(VoH, etaI, etaT);
        float D = D_GGX(NoH, alpha);
        float G = G_SmithGGX(abs(NoV), abs(NoL), alpha);

        float denom = etaI * VoH + etaT * LoH;
        float factor = (VoH * LoH) /
            max(abs(NoV) * abs(NoL) * denom * denom, 1e-8);

        return ((1.0 - F) * D * G * factor);
    }
}

float pdfDielectricMicrofacet(
    vec3 N,
    vec3 V,
    vec3 L,
    float roughness,
    float etaI,
    float etaT
) {
    float NoV = dot(N, V);
    float NoL = dot(N, L);

    if (abs(NoV) < 1e-6 || abs(NoL) < 1e-6) {
        return 0.0;
    }

    float alpha = max(0.001, roughness * roughness);
    bool reflectMode = (NoV * NoL > 0.0);

    if (reflectMode) {
        vec3 H = normalize(V + L);
        if (dot(H, N) < 0.0) H = -H;

        float NoH = saturate(dot(N, H));
        float VoH = abs(dot(V, H));
        if (VoH <= 1e-8) return 0.0;

        float D = D_GGX(NoH, alpha);
        float pdfH = D * NoH;
        return pdfH / max(4.0 * VoH, 1e-8);
    } else {
        vec3 Hraw = -(etaI * V + etaT * L);
        float h2 = dot(Hraw, Hraw);
        if (h2 <= 1e-12) {
            return 0.0;
        }
        vec3 H = Hraw * inversesqrt(h2);
        if (dot(H, N) < 0.0) H = -H;

        float NoH = saturate(dot(N, H));
        float VoH = abs(dot(V, H));
        float LoH = abs(dot(L, H));

        float denom = etaI * VoH + etaT * LoH;
        if (VoH <= 1e-8 || LoH <= 1e-8 || denom <= 1e-8) {
            return 0.0;
        }

        float D = D_GGX(NoH, alpha);
        float pdfH = D * NoH;

        float dwh_dwo = (etaT * etaT * LoH) / max(denom * denom, 1e-8);
        return pdfH * dwh_dwo;
    }
}

DielectricSample sampleDielectricBSDF(
    vec3 N,
    vec3 V,
    bool frontFace,
    float albedoS,
    float smoothness,
    float ior,
    inout uint rng
) {
    DielectricSample s;
    s.dir = vec3(0.0);
    s.f = 0.0;
    s.pdf = 0.0;
    s.isTransmission = 0u;
    s.isDelta = 0u;

    float roughness = roughnessFromSmoothness(smoothness);
    float etaI = frontFace ? 1.0 : ior;
    float etaT = frontFace ? ior : 1.0;
    float eta  = etaI / etaT;

    // Rough dielectric (I don't handle delta dielectric because I don't want to. Also, it's not technically required)
    float alpha = alphaFromSmoothness(smoothness);
    vec3 H = sampleGGXHalfVector(N, alpha, vec2(rand01(rng), rand01(rng)));
    if (dot(V, H) < 0.0) {
        H = -H;
    }

    float Fr = fresnelDielectric(clamp(abs(dot(V, H)), 0.0, 1.0), etaI, etaT);

    if (isDeltaSpecular(smoothness)) {
        float Fr = fresnelDielectric(clamp(dot(V, N), 0.0, 1.0), etaI, etaT);

        if (rand01(rng) < Fr) {
            vec3 L = reflect(-V, N);
            float absNoL = max(abs(dot(N, L)), 1e-8);

            s.dir = normalize(L);
            s.f = Fr / absNoL;
            s.pdf = max(Fr, 1e-8);
            s.isTransmission = 0u;
            s.isDelta = 1u;
            return s;
        } else {
            vec3 L;
            if (!refractDir(-V, N, eta, L)) {
                return s;
            }

            float absNoL = max(abs(dot(N, L)), 1e-8);

            s.dir = normalize(L);
            s.f = (1.0 - Fr) / absNoL;
            s.pdf = max(1.0 - Fr, 1e-8);
            s.isTransmission = 1u;
            s.isDelta = 1u;
            return s;
        }
    }

    if (rand01(rng) < Fr) {
        vec3 L = reflect(-V, H);

        float NoV = abs(dot(N, V));
        float NoL = abs(dot(N, L));
        if (NoV <= 1e-8 || NoL <= 1e-8) {
            return s;
        }

        bool isTransmission = false;
        float f = evalDielectricMicrofacet(N, V, L, roughness, etaI, etaT, isTransmission);
        float pdf = pdfDielectricMicrofacet(N, V, L, roughness, etaI, etaT);

        if (isTransmission || f <= 1e-8 || pdf <= 1e-8) {
            return s;
        }

        s.dir = normalize(L);
        s.f = f;
        s.pdf = max(Fr * pdf, 1e-8);
        s.isTransmission = 0u;
        s.isDelta = 0u;
        return s;
    } else {
        vec3 L;
        if (!refractDir(-V, H, eta, L)) {
            return s;
        }

        float NoV = abs(dot(N, V));
        float NoL = abs(dot(N, L));
        if (NoV <= 1e-8 || NoL <= 1e-8) {
            return s;
        }

        bool isTransmission = false;
        float f = evalDielectricMicrofacet(N, V, L, roughness, etaI, etaT, isTransmission);
        float pdf = pdfDielectricMicrofacet(N, V, L, roughness, etaI, etaT);

        if (!isTransmission || f <= 1e-8 || pdf <= 1e-8) {
            return s;
        }

        s.dir = normalize(L);
        s.f = f;
        s.pdf = max((1.0 - Fr) * pdf, 1e-8);
        s.isTransmission = 1u;
        s.isDelta = 0u;
        return s;
    }
}

float evalBSDFScalar(
    vec3 N,
    vec3 V,
    vec3 L,
    float albedoS,
    float smoothness,
    float metallic,
    Material mat,
    float lambda
) {
    float NoV = saturate(dot(N, V));
    float NoL = saturate(dot(N, L));
    if (NoV <= 0.0 || NoL <= 0.0) return 0.0;

    vec3 H = normalize(V + L);
    float NoH = saturate(dot(N, H));
    float VoH = saturate(dot(V, H));

    float roughness = roughnessFromSmoothness(smoothness);
    float alpha = roughness * roughness;

    float transmission = mat.metallic_smoothShading_transmission_ior.z;
    float filmThickness = mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.y;

    float F;
    if (transmission <= 0.001 && filmThickness > 0.0) {
        F = thinFilmReflectanceOpaque(mat, lambda, VoH);
    } else {
        float F0 = mix(0.04, albedoS, metallic);
        F = fresnelSchlickScalar(VoH, F0);
    }

    float D = D_GGX(NoH, alpha);
    float G = G_SmithGGX(NoV, NoL, alpha);

    float spec = (D * G * F) / max(4.0 * NoV * NoL, 1e-8);
    float kd = (1.0 - F) * (1.0 - metallic);
    float diff = kd * albedoS / PI;

    return diff + spec;
}

bool traceClosestMaxT(
    vec3 ro,
    vec3 rd,
    float tMax,
    out uint outPrim,
    out float outTHit,
    out vec2 outBary
) {
    rayQueryEXT rq;
    rayQueryInitializeEXT(
        rq,
        sceneTLAS,
        gl_RayFlagsOpaqueEXT,
        0xFF,
        ro,
        EPS,
        rd,
        tMax
    );

    while (rayQueryProceedEXT(rq)) {}

    if (rayQueryGetIntersectionTypeEXT(rq, true) == gl_RayQueryCommittedIntersectionNoneEXT) {
        return false;
    }

    outPrim = rayQueryGetIntersectionPrimitiveIndexEXT(rq, true);
    outTHit = rayQueryGetIntersectionTEXT(rq, true);
    outBary = rayQueryGetIntersectionBarycentricsEXT(rq, true);
    return true;
}

bool pointInTriBary(vec2 uv) {
    float u = uv.x;
    float v = uv.y;
    float w = 1.0 - u - v;
    return u >= 0.0 && v >= 0.0 && w >= 0.0;
}

vec3 triPoint(uint prim, vec2 uv) {
    vec3 v0, v1, v2;
    loadTriangle(prim, v0, v1, v2);
    float u = uv.x;
    float v = uv.y;
    float w = 1.0 - u - v;
    return v0 * w + v1 * u + v2 * v;
}

vec3 triNormalFlat(uint prim) {
    vec3 v0, v1, v2;
    loadTriangle(prim, v0, v1, v2);
    return triangleNormal(v0, v1, v2);
}

vec3 triPointUnclamped(uint prim, vec2 uv) {
    vec3 v0, v1, v2;
    loadTriangle(prim, v0, v1, v2);
    float u = uv.x;
    float v = uv.y;
    float w = 1.0 - u - v;
    return v0 * w + v1 * u + v2 * v;
}

uint quadAlternateIfSameMat(uint triId) {
    uint alt = triId ^ 1u;
    if (triangleMaterialIndices[alt] == triangleMaterialIndices[triId]) {
        return alt;
    }
    return triId;
}

float triAreaJacobianUv(uint triId) {
    vec3 a, b, c;
    loadTriangle(triId, a, b, c);
    return length(cross(b - a, c - a));
}

bool isMneeSpecular(Material mat) {
    return mat.metallic_smoothShading_transmission_ior.z > 0.0 &&
           mat.albedo_smoothness.w >= MNEE_SPEC_SMOOTH;
}

void tangentBasisFromN(vec3 n, out vec3 T, out vec3 B) {
    T = orthonormalT(n);
    B = cross(n, T);
}

float maxAbsConstraint2(vec2 c) {
    return max(abs(c.x), abs(c.y));
}

float maxAbsConstraint4(vec4 c) {
    return max(max(abs(c.x), abs(c.y)), max(abs(c.z), abs(c.w)));
}

vec3 triShadeNormalAt(uint prim, vec2 bary, vec3 rayDir) {
    uint i0 = indexData[prim * 3u + 0u];
    uint i1 = indexData[prim * 3u + 1u];
    uint i2 = indexData[prim * 3u + 2u];

    float b1 = bary.x;
    float b2 = bary.y;
    float b0 = 1.0 - b1 - b2;

    vec3 geomN = triNormalFlat(prim);
    bool frontFace = dot(rayDir, geomN) < 0.0;
    vec3 Ng = frontFace ? geomN : -geomN;

    Material mat = materials[triangleMaterialIndices[prim]];
    float smoothShading = mat.metallic_smoothShading_transmission_ior.y;

    vec3 n0 = loadNormal(i0);
    vec3 n1 = loadNormal(i1);
    vec3 n2 = loadNormal(i2);

    vec3 smoothN = normalize(n0 * b0 + n1 * b1 + n2 * b2);
    vec3 rawShadeN = (smoothShading > 0.5) ? smoothN : Ng;

    return normalize(dot(rawShadeN, Ng) >= 0.0 ? rawShadeN : -rawShadeN);
}

bool isDeltaTransmissivePrim(uint prim) {
    Material mat = materials[triangleMaterialIndices[prim]];
    return mat.metallic_smoothShading_transmission_ior.z > 0.001 &&
           isDeltaSpecular(mat.albedo_smoothness.w);
}

float spectralAbsorptionAtPrim(uint prim, float lambda) {
    Material mat = materials[triangleMaterialIndices[prim]];
    float specAlb = rgb_to_reflectance_spectrum(lambda, mat.albedo_smoothness.xyz);
    return -log(max(specAlb, 1e-3));
}

float primIorAtLambda(uint prim, float lambda) {
    Material mat = materials[triangleMaterialIndices[prim]];
    return iorAtLambda(
        mat.metallic_smoothShading_transmission_ior.w,
        mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.x,
        lambda
    );
}

bool refractOrFail(vec3 I, vec3 N, float etaI, float etaT, out vec3 T) {
    return refractDir(I, N, etaI / etaT, T);
}

void tangentFrameAtSpecPoint(uint prim, vec2 uv, vec3 rayDir, out vec3 T, out vec3 B, out vec3 N) {
    N = triShadeNormalAt(prim, uv, rayDir);
    makeBasis(N, T, B);
}

vec4 manifoldResidualTwoRefraction(
    vec3 receiverPos,
    vec3 lightPos,
    uint prim1,
    uint prim2,
    vec2 uv1,
    vec2 uv2,
    float lambda
) {
    vec3 P1 = triPoint(prim1, uv1);
    vec3 P2 = triPoint(prim2, uv2);

    vec3 d0 = normalize(P1 - receiverPos);
    vec3 d1 = normalize(P2 - P1);
    vec3 d2 = normalize(lightPos - P2);

    vec3 T1, B1, N1;
    tangentFrameAtSpecPoint(prim1, uv1, d0, T1, B1, N1);

    vec3 T2, B2, N2;
    tangentFrameAtSpecPoint(prim2, uv2, d1, T2, B2, N2);

    float ior1 = primIorAtLambda(prim1, lambda);
    float ior2 = primIorAtLambda(prim2, lambda);

    vec3 pred1;
    if (!refractOrFail(d0, N1, 1.0, ior1, pred1)) {
        return vec4(1e4);
    }

    vec3 pred2;
    if (!refractOrFail(d1, N2, ior2, 1.0, pred2)) {
        return vec4(1e4);
    }

    vec3 e1 = d1 - pred1;
    vec3 e2 = d2 - pred2;

    return vec4(
        dot(T1, e1),
        dot(B1, e1),
        dot(T2, e2),
        dot(B2, e2)
    );
}

float residualNorm2(vec4 r) {
    return dot(r, r);
}

mat4 numericalJacobianTwoRefraction(
    vec3 receiverPos,
    vec3 lightPos,
    uint prim1,
    uint prim2,
    vec2 uv1,
    vec2 uv2,
    float lambda
) {
    vec4 r0 = manifoldResidualTwoRefraction(receiverPos, lightPos, prim1, prim2, uv1, uv2, lambda);

    float h = 1e-4;
    mat4 J = mat4(0.0);

    for (int c = 0; c < 4; ++c) {
        vec2 u1p = uv1;
        vec2 u2p = uv2;

        if (c == 0) u1p.x += h;
        if (c == 1) u1p.y += h;
        if (c == 2) u2p.x += h;
        if (c == 3) u2p.y += h;

        vec4 rp = manifoldResidualTwoRefraction(receiverPos, lightPos, prim1, prim2, u1p, u2p, lambda);
        vec4 col = (rp - r0) / h;

        J[c][0] = col.x;
        J[c][1] = col.y;
        J[c][2] = col.z;
        J[c][3] = col.w;
    }

    return J;
}

// Solves A x = b in place. Returns false if singular.
bool solveLinear4(in mat4 A, in vec4 b, out vec4 x) {
    float M[4][5];

    for (int r = 0; r < 4; ++r) {
        for (int c = 0; c < 4; ++c) {
            M[r][c] = A[c][r];
        }
    }
    M[0][4] = b.x;
    M[1][4] = b.y;
    M[2][4] = b.z;
    M[3][4] = b.w;

    for (int k = 0; k < 4; ++k) {
        int piv = k;
        float best = abs(M[k][k]);
        for (int r = k + 1; r < 4; ++r) {
            float v = abs(M[r][k]);
            if (v > best) {
                best = v;
                piv = r;
            }
        }

        if (best < 1e-10) {
            x = vec4(0.0);
            return false;
        }

        if (piv != k) {
            for (int c = k; c < 5; ++c) {
                float tmp = M[k][c];
                M[k][c] = M[piv][c];
                M[piv][c] = tmp;
            }
        }

        float invPivot = 1.0 / M[k][k];
        for (int c = k; c < 5; ++c) {
            M[k][c] *= invPivot;
        }

        for (int r = 0; r < 4; ++r) {
            if (r == k) continue;
            float f = M[r][k];
            for (int c = k; c < 5; ++c) {
                M[r][c] -= f * M[k][c];
            }
        }
    }

    x = vec4(M[0][4], M[1][4], M[2][4], M[3][4]);
    return true;
}

bool newtonSolveTwoRefractionManifold(
    vec3 receiverPos,
    vec3 lightPos,
    uint prim1,
    uint prim2,
    float lambda,
    inout vec2 uv1,
    inout vec2 uv2,
    out mat4 outJ,
    out float outDetJ
) {
    outJ = mat4(0.0);
    outDetJ = 0.0;

    const int MAX_ITERS = 12;
    const float TOL = 1e-10;

    for (int it = 0; it < MAX_ITERS; ++it) {
        vec4 r = manifoldResidualTwoRefraction(receiverPos, lightPos, prim1, prim2, uv1, uv2, lambda);
        float err2 = residualNorm2(r);
        if (err2 < TOL) {
            outJ = numericalJacobianTwoRefraction(receiverPos, lightPos, prim1, prim2, uv1, uv2, lambda);
            outDetJ = determinant(outJ);
            return abs(outDetJ) > 1e-12;
        }

        mat4 J = numericalJacobianTwoRefraction(receiverPos, lightPos, prim1, prim2, uv1, uv2, lambda);
        vec4 step;
        if (!solveLinear4(J, -r, step)) {
            return false;
        }

        float alpha = 1.0;
        bool accepted = false;
        for (int ls = 0; ls < 8; ++ls) {
            vec2 cand1 = uv1 + alpha * step.xy;
            vec2 cand2 = uv2 + alpha * step.zw;

            if (pointInTriBary(cand1) && pointInTriBary(cand2)) {
                vec4 rc = manifoldResidualTwoRefraction(receiverPos, lightPos, prim1, prim2, cand1, cand2, lambda);
                if (residualNorm2(rc) < err2) {
                    uv1 = cand1;
                    uv2 = cand2;
                    accepted = true;
                    break;
                }
            }

            alpha *= 0.5;
        }

        if (!accepted) {
            return false;
        }
    }

    vec4 r = manifoldResidualTwoRefraction(receiverPos, lightPos, prim1, prim2, uv1, uv2, lambda);
    if (residualNorm2(r) >= 1e-8) {
        return false;
    }

    outJ = numericalJacobianTwoRefraction(receiverPos, lightPos, prim1, prim2, uv1, uv2, lambda);
    outDetJ = determinant(outJ);
    return abs(outDetJ) > 1e-12;
}

bool segmentHitsExpected(
    vec3 o0,
    vec3 p1,
    int expectedTri
) {
    if (expectedTri < 0) return false;

    vec3 d = p1 - o0;
    float dist2 = dot(d, d);
    if (dist2 <= 1e-12) return false;

    float dist = sqrt(dist2);
    vec3 dir = d / dist;

    float epsSeg = EPS_RAY * 5.0;
    vec3 o = o0 + dir * epsSeg;

    float expectedT = dot(p1 - o, dir);
    if (expectedT <= 0.0) return false;

    uint prim;
    float tHit;
    vec2 bary;
    if (!traceClosestMaxT(o, dir, expectedT + epsSeg, prim, tHit, bary)) {
        return false;
    }

    if (int(prim) != expectedTri) {
        return false;
    }

    return abs(tHit - expectedT) < epsSeg * 2.0;
}

bool segmentHitsExpectedQuad(
    vec3 o0,
    vec3 p1,
    int expectedTri
) {
    if (expectedTri < 0) return false;

    vec3 d = p1 - o0;
    float dist2 = dot(d, d);
    if (dist2 <= 1e-12) return false;

    float dist = sqrt(dist2);
    vec3 dir = d / dist;

    float epsSeg = EPS_RAY * 5.0;
    vec3 o = o0 + dir * epsSeg;

    float expectedT = dot(p1 - o, dir);
    if (expectedT <= 0.0) return false;

    uint prim;
    float tHit;
    vec2 bary;
    if (!traceClosestMaxT(o, dir, expectedT + epsSeg, prim, tHit, bary)) {
        return false;
    }

    uint triU = uint(expectedTri);
    uint altU = quadAlternateIfSameMat(triU);

    if (prim != triU && prim != altU) {
        return false;
    }

    return abs(tHit - expectedT) < epsSeg * 2.0;
}

bool validateSegmentHit(
    vec3 a,
    vec3 b,
    uint expectedPrim,
    out float outT
) {
    vec3 d = b - a;
    float dist = length(d);
    if (dist <= 1e-8) {
        outT = 0.0;
        return false;
    }

    vec3 rd = d / dist;
    uint prim;
    float tHit;
    vec2 bary;
    if (!traceClosestMaxT(a, rd, dist + 1e-4, prim, tHit, bary)) {
        outT = 0.0;
        return false;
    }

    outT = tHit;
    return prim == expectedPrim;
}

bool sampleTransmissivePoint(
    inout uint rng,
    uint transmissiveCount,
    vec3 receiverPos,
    out uint triIndex,
    out vec3 x,
    out vec3 N,
    out float ior,
    out float pdfAreaOnSurface,
    out vec2 uv
) {
    if (transmissiveCount == 0u) return false;

    uint slot = sampleTransmissiveTriangle(rand01(rng), transmissiveCount);
    triIndex = transmissiveTriangles[slot].triIndex_pad.x;

    float triArea = transmissiveTriangles[slot].area_pmf_cdf_pad.x;
    float triPmf  = transmissiveTriangles[slot].area_pmf_cdf_pad.y;
    if (triArea <= 0.0 || triPmf <= 0.0) return false;

    vec3 a, b, c;
    loadTriangle(triIndex, a, b, c);

    vec3 Ng = triangleNormal(a, b, c);
    N = dot(Ng, receiverPos - baryToPoint(vec3(1.0/3.0), a, b, c)) > 0.0 ? Ng : -Ng;

    Material m = materials[triangleMaterialIndices[triIndex]];
    ior = m.metallic_smoothShading_transmission_ior.w;

    vec3 planeP = receiverPos - N * dot(receiverPos - a, N);

    vec3 bcCenter;
    bool haveProj = pointToTriangleBary(planeP, a, b, c, bcCenter);

    if (!haveProj || any(lessThan(bcCenter, vec3(0.0)))) {
        vec3 rawBc;
        pointToTriangleBary(planeP, a, b, c, rawBc);
        rawBc = max(rawBc, vec3(0.0));
        float s = rawBc.x + rawBc.y + rawBc.z;
        if (s > 1e-8) {
            bcCenter = rawBc / s;
        } else {
            bcCenter = vec3(1.0 / 3.0);
        }
    }

    const float guideMix  = 0.9;
    const float sigmaBary = 0.12;

    vec3 bc;
    float pdfGuidedLocal = 0.0;
    bool usedGuided = false;

    if (rand01(rng) < guideMix) {
        if (sampleTriangleGuidedBary(bcCenter, sigmaBary, rng, bc, pdfGuidedLocal)) {
            usedGuided = true;
        }
    }

    if (!usedGuided) {
        vec2 u = sampleUniformTriangle(vec2(rand01(rng), rand01(rng)));
        bc = vec3(1.0 - u.x - u.y, u.x, u.y);
    }

    x = baryToPoint(bc, a, b, c);
    uv = vec2(bc.y, bc.z);

    float pdfUniformArea = triPmf / triArea;

    float pdfGuidedArea = triPmf * pdfGuidedLocal / max(triArea, 1e-8);

    if (usedGuided) {
        pdfAreaOnSurface =
            guideMix * pdfGuidedArea +
            (1.0 - guideMix) * pdfUniformArea;
    } else {
        pdfAreaOnSurface =
            (1.0 - guideMix) * pdfUniformArea;
    }

    if (!usedGuided) {
        vec3 d = bc - bcCenter;
        float dv = d.y;
        float dw = d.z;
        float g = exp(-0.5 * (dv * dv + dw * dw) / max(sigmaBary * sigmaBary, 1e-8));
        float guidedAtSample = g / max(2.0 * PI * sigmaBary * sigmaBary, 1e-8);
        float guidedAreaAtSample = triPmf * guidedAtSample / max(triArea, 1e-8);

        pdfAreaOnSurface =
            guideMix * guidedAreaAtSample +
            (1.0 - guideMix) * pdfUniformArea;
    }

    return pdfAreaOnSurface > 0.0;
}

bool predictGuidedLightPoint(
    vec3 receiverPos,
    vec3 receiverN,
    vec3 xt,
    vec3 Nt,
    float ior,
    bool frontFaceAtXt,
    vec3 lightA,
    vec3 lightB,
    vec3 lightC,
    out vec3 yPred
) {
    vec3 wi = normalize(xt - receiverPos);

    float etaI = 1.0;
    float etaT = ior;

    vec3 dirInside;
    if (!refractDir(wi, Nt, etaI / etaT, dirInside)) {
        dirInside = reflect(wi, Nt);
    }

    vec3 lightN = triangleNormal(lightA, lightB, lightC);
    float denom = dot(lightN, dirInside);
    if (abs(denom) < 1e-6) {
        return false;
    }

    float tPlane = dot(lightN, lightA - xt) / denom;
    if (tPlane <= 0.0) {
        return false;
    }

    yPred = xt + dirInside * tPlane;
    return true;
}

MneeSeed buildMneeSeed(
    vec3 x0,
    vec3 n0,
    vec3 y,
    float lambda,
    uint tri0,
    vec2 uv0
) {
    MneeSeed s;
    s.count = 0u;
    for (uint i = 0u; i < 3u; ++i) {
        s.tri[i] = 0u;
        s.uv[i]  = vec2(0.0);
        s.evt[i] = EVT_REFRACT;
    }

    // First event is provided by the receiver-dependent seed point.
    s.count = 1u;
    s.tri[0] = tri0;
    s.uv[0]  = uv0;
    s.evt[0] = EVT_REFRACT;

    vec3 p0 = triPointUnclamped(tri0, uv0);

    vec3 d01 = y - p0;
    float dist01 = length(d01);
    if (dist01 <= 1e-8) {
        return s;
    }

    vec3 rayD = d01 / dist01;
    vec3 rayO = p0 + rayD * EPS;
    float tRemain = dist01 - EPS;

    // Find up to one more transmissive event on the way to the light.
    // That gives the common 2-refraction caustic case.
    for (uint i = 1u; i < 2u; ++i) {
        if (tRemain <= 1e-5) break;

        uint triHit;
        float tHit;
        vec2 uvHit;
        if (!traceClosestMaxT(rayO, rayD, tRemain, triHit, tHit, uvHit)) {
            break;
        }

        // Skip self / same quad partner if needed
        if (triHit == s.tri[i - 1u] || triHit == quadAlternateIfSameMat(s.tri[i - 1u])) {
            float adv = tHit + EPS;
            rayO += rayD * adv;
            tRemain -= adv;
            continue;
        }

        Material matHit = materials[triangleMaterialIndices[triHit]];
        if (!isMneeSpecular(matHit)) {
            break;
        }

        s.tri[s.count] = triHit;
        s.uv[s.count]  = uvHit;
        s.evt[s.count] = EVT_REFRACT;
        s.count++;

        float adv = tHit + EPS;
        rayO += rayD * adv;
        tRemain -= adv;
    }

    // Optional refract-reflect-refract extension, same spirit as your old builder.
    if (s.count < 2u) {
        return s;
    }

    vec3 p1 = triPointUnclamped(s.tri[1], s.uv[1]);
    vec3 wi = normalize(p1 - p0);

    vec3 n1 = triNormalFlat(s.tri[1]);
    float etaGlass = materialIorAtLambda(s.tri[1], lambda);

    float etaI = etaGlass;
    float etaT = 1.0;

    if (dot(wi, n1) > 0.0) {
        n1 = -n1;
        float tmp = etaI;
        etaI = etaT;
        etaT = tmp;
    }

    vec3 tdir;
    bool hasTransmit = refractDir(wi, n1, etaI / etaT, tdir);

    bool wantsReflect = !hasTransmit;
    if (!wantsReflect) {
        return s;
    }

    vec3 rdir = reflect(wi, n1);
    vec3 o2 = p1 + rdir * EPS;

    uint tri2;
    float t2;
    vec2 uv2;
    if (!traceClosestMaxT(o2, rdir, INF_T, tri2, t2, uv2)) {
        return s;
    }

    if (!isDeltaTransmissivePrim(tri2)) {
        return s;
    }

    s.count = 3u;
    s.evt[0] = EVT_REFRACT;
    s.evt[1] = EVT_REFLECT;
    s.tri[2] = tri2;
    s.uv[2]  = uv2;
    s.evt[2] = EVT_REFRACT;

    return s;
}

vec2 specConstraintReflect(
    vec3 prevP,
    vec3 thisP,
    vec3 nextP,
    uint triId
) {
    vec3 wi = normalize(thisP - prevP);

    vec3 n = triNormalFlat(triId);
    if (dot(wi, n) > 0.0) {
        n = -n;
    }

    vec3 rdir = reflect(wi, n);
    vec3 wo   = normalize(nextP - thisP);

    vec3 T, B;
    tangentBasisFromN(n, T, B);

    vec3 diff = wo - rdir;
    return vec2(dot(diff, T), dot(diff, B));
}

vec2 specConstraintRefract(
    vec3 prevP,
    vec3 thisP,
    vec3 nextP,
    uint triId,
    float etaFrom,
    float etaTo,
    float lambda
) {
    vec3 wi = normalize(thisP - prevP);

    vec3 n = triNormalFlat(triId);

    float etaI = etaFrom;
    float etaT = etaTo;

    if (dot(wi, n) > 0.0) {
        n = -n;
        float tmp = etaI;
        etaI = etaT;
        etaT = tmp;
    }

    vec3 tdir;
    if (!refractDir(wi, n, etaI / etaT, tdir)) {
        return vec2(1e3, 1e3);
    }

    vec3 wo = normalize(nextP - thisP);

    vec3 T, B;
    tangentBasisFromN(n, T, B);

    vec3 diff = wo - normalize(tdir);
    return vec2(dot(diff, T), dot(diff, B));
}

bool solveLinear2(mat2 A, vec2 b, out vec2 x) {
    float det = A[0][0] * A[1][1] - A[0][1] * A[1][0];
    if (abs(det) < 1e-10) {
        x = vec2(0.0);
        return false;
    }

    float invDet = 1.0 / det;
    x = vec2(
        ( b.x * A[1][1] - b.y * A[0][1]) * invDet,
        (-b.x * A[1][0] + b.y * A[0][0]) * invDet
    );
    return true;
}

bool solveLinear6(in float Ain[6][6], in float bin[6], out float x[6], out float detOut) {
    float M[6][7];

    for (int r = 0; r < 6; ++r) {
        for (int c = 0; c < 6; ++c) {
            M[r][c] = Ain[r][c];
        }
        M[r][6] = bin[r];
    }

    detOut = 1.0;

    for (int k = 0; k < 6; ++k) {
        int piv = k;
        float best = abs(M[k][k]);

        for (int r = k + 1; r < 6; ++r) {
            float v = abs(M[r][k]);
            if (v > best) {
                best = v;
                piv = r;
            }
        }

        if (best < 1e-10) {
            for (int i = 0; i < 6; ++i) x[i] = 0.0;
            detOut = 0.0;
            return false;
        }

        if (piv != k) {
            for (int c = k; c < 7; ++c) {
                float tmp = M[k][c];
                M[k][c] = M[piv][c];
                M[piv][c] = tmp;
            }
            detOut = -detOut;
        }

        float pivot = M[k][k];
        detOut *= pivot;

        float invPivot = 1.0 / pivot;
        for (int c = k; c < 7; ++c) {
            M[k][c] *= invPivot;
        }

        for (int r = 0; r < 6; ++r) {
            if (r == k) continue;
            float f = M[r][k];
            if (abs(f) < 1e-12) continue;

            for (int c = k; c < 7; ++c) {
                M[r][c] -= f * M[k][c];
            }
        }
    }

    for (int i = 0; i < 6; ++i) {
        x[i] = M[i][6];
    }
    return true;
}

vec2 mneeConstraints1(
    vec3 x0,
    vec3 y,
    MneeSeed seed,
    float lambda
) {
    vec3 x[3];
    x[0] = triPointUnclamped(seed.tri[0], seed.uv[0]);

    vec3 prevP = x0;
    vec3 thisP = x[0];
    vec3 nextP = y;

    if (seed.evt[0] == EVT_REFLECT) {
        return specConstraintReflect(prevP, thisP, nextP, seed.tri[0]);
    } else {
        Material matS = materials[triangleMaterialIndices[seed.tri[0]]];
        float etaMat = materialIorAtLambda(seed.tri[0], lambda);

        float etaFrom = 1.0;
        float etaTo   = etaMat;

        return specConstraintRefract(prevP, thisP, nextP, seed.tri[0], etaFrom, etaTo, lambda);
    }
}

vec4 mneeConstraints2(
    vec3 x0,
    vec3 y,
    MneeSeed seed,
    float lambda
) {
    vec3 x[3];
    x[0] = triPointUnclamped(seed.tri[0], seed.uv[0]);
    x[1] = triPointUnclamped(seed.tri[1], seed.uv[1]);

    vec4 C = vec4(0.0);

    float etaFrom = 1.0;

    for (uint i = 0u; i < 2u; ++i) {
        vec3 prevP = (i == 0u) ? x0 : x[i - 1u];
        vec3 thisP = x[i];
        vec3 nextP = (i == 1u) ? y : x[i + 1u];

        vec2 c;
        if (seed.evt[i] == EVT_REFLECT) {
            c = specConstraintReflect(prevP, thisP, nextP, seed.tri[i]);
        } else {
            float etaMat = materialIorAtLambda(seed.tri[i], lambda);
            float etaTo = (etaFrom == 1.0) ? etaMat : 1.0;
            c = specConstraintRefract(prevP, thisP, nextP, seed.tri[i], etaFrom, etaTo, lambda);
            etaFrom = etaTo;
        }

        C[int(2u * i + 0u)] = c.x;
        C[int(2u * i + 1u)] = c.y;
    }

    return C;
}

void mneeConstraints3(
    vec3 x0,
    vec3 y,
    MneeSeed seed,
    float lambda,
    out float C[6]
) {
    for (int k = 0; k < 6; ++k) C[k] = 0.0;

    vec3 x[3];
    x[0] = triPointUnclamped(seed.tri[0], seed.uv[0]);
    x[1] = triPointUnclamped(seed.tri[1], seed.uv[1]);
    x[2] = triPointUnclamped(seed.tri[2], seed.uv[2]);

    float etaFrom = 1.0;

    for (uint i = 0u; i < 3u; ++i) {
        vec3 prevP = (i == 0u) ? x0 : x[i - 1u];
        vec3 thisP = x[i];
        vec3 nextP = (i == 2u) ? y : x[i + 1u];

        vec2 c;
        if (seed.evt[i] == EVT_REFLECT) {
            c = specConstraintReflect(prevP, thisP, nextP, seed.tri[i]);
        } else {
            float etaMat = materialIorAtLambda(seed.tri[i], lambda);
            float etaTo = (etaFrom == 1.0) ? etaMat : 1.0;
            c = specConstraintRefract(prevP, thisP, nextP, seed.tri[i], etaFrom, etaTo, lambda);
            etaFrom = etaTo;
        }

        C[int(2u * i + 0u)] = c.x;
        C[int(2u * i + 1u)] = c.y;
    }
}

mat4 mneeJacobian2FiniteDiff(
    vec3 x0,
    vec3 y,
    MneeSeed s,
    float lambda
) {
    vec4 C0 = mneeConstraints2(x0, y, s, lambda);

    MneeSeed sp;
    vec4 C1, d0, d1, d2, d3;

    sp = s;
    sp.uv[0] += vec2(MNEE_EPS_UV, 0.0);
    C1 = mneeConstraints2(x0, y, sp, lambda);
    d0 = (C1 - C0) / MNEE_EPS_UV;

    sp = s;
    sp.uv[0] += vec2(0.0, MNEE_EPS_UV);
    C1 = mneeConstraints2(x0, y, sp, lambda);
    d1 = (C1 - C0) / MNEE_EPS_UV;

    sp = s;
    sp.uv[1] += vec2(MNEE_EPS_UV, 0.0);
    C1 = mneeConstraints2(x0, y, sp, lambda);
    d2 = (C1 - C0) / MNEE_EPS_UV;

    sp = s;
    sp.uv[1] += vec2(0.0, MNEE_EPS_UV);
    C1 = mneeConstraints2(x0, y, sp, lambda);
    d3 = (C1 - C0) / MNEE_EPS_UV;

    mat4 J = mat4(0.0);
    J[0] = vec4(d0.x, d0.y, d0.z, d0.w);
    J[1] = vec4(d1.x, d1.y, d1.z, d1.w);
    J[2] = vec4(d2.x, d2.y, d2.z, d2.w);
    J[3] = vec4(d3.x, d3.y, d3.z, d3.w);
    return J;
}

float maxAbsVec4(vec4 v) {
    return max(max(abs(v.x), abs(v.y)), max(abs(v.z), abs(v.w)));
}

vec4 mulMat4Vec4(mat4 A, vec4 x) {
    // Your solveLinear4 treats A[c][r] as column-major and solves with that convention.
    // J * x in GLSL already matches that layout.
    return A * x;
}

void broydenUpdateGood4(
    inout mat4 J,
    vec4 sStep,
    vec4 yDiff
) {
    float denom = dot(sStep, sStep);
    if (denom <= 1e-12) return;

    vec4 Js = mulMat4Vec4(J, sStep);
    vec4 u = yDiff - Js;

    // Good Broyden:
    // J_{k+1} = J_k + ((y - J s) s^T) / (s^T s)
    J[0] += u * (sStep.x / denom);
    J[1] += u * (sStep.y / denom);
    J[2] += u * (sStep.z / denom);
    J[3] += u * (sStep.w / denom);
}

bool mneeSolveStep2(
    vec3 x0,
    vec3 y,
    float lambda,
    vec4 C0,
    inout MneeSeed s,
    inout mat4 J,
    out vec4 C1,
    out float stepScaleUsed
) {
    C1 = C0;
    stepScaleUsed = 0.0;

    vec4 step;
    if (!solveLinear4(J, -C0, step)) {
        return false;
    }

    // UV trust region
    float maxStep = 0.10;
    float smax = maxAbsVec4(step);
    if (smax > maxStep) {
        step *= maxStep / smax;
    }

    float alpha = 1.0;
    float err0 = dot(C0, C0);

    for (int ls = 0; ls < 6; ++ls) {
        MneeSeed cand = s;
        cand.uv[0] += alpha * step.xy;
        cand.uv[1] += alpha * step.zw;

        if (!pointInTriBary(cand.uv[0]) || !pointInTriBary(cand.uv[1])) {
            alpha *= 0.5;
            continue;
        }

        vec4 Ccand = mneeConstraints2(x0, y, cand, lambda);
        float err1 = dot(Ccand, Ccand);

        if (err1 < err0) {
            s = cand;
            C1 = Ccand;
            stepScaleUsed = alpha;
            return true;
        }

        alpha *= 0.5;
    }

    return false;
}

MneeSolve mneeNewtonsSolve(
    vec3 x0,
    vec3 y,
    float lambda,
    MneeSeed seed0
) {
    MneeSolve outSolve;
    outSolve.ok = false;
    outSolve.invAbsDetJ = 0.0;
    outSolve.seed = seed0;

    MneeSeed s = seed0;
    if (s.count == 0u) {
        return outSolve;
    }

    float invAbsDetJ = 0.0;

    const uint MNEE_ITERS = 3u;

    for (uint it = 0u; it < MNEE_ITERS; ++it) {
        if (s.count == 1u) {
            vec2 C0 = mneeConstraints1(x0, y, s, lambda);
            if (maxAbsConstraint2(C0) < MNEE_EPS_C) {
                outSolve.ok = true;
                outSolve.invAbsDetJ = invAbsDetJ;
                outSolve.seed = s;
                return outSolve;
            }

            MneeSeed sp = s;
            sp.uv[0] += vec2(MNEE_EPS_UV, 0.0);
            vec2 Cp = mneeConstraints1(x0, y, sp, lambda);
            vec2 J0 = (Cp - C0) / MNEE_EPS_UV;

            sp = s;
            sp.uv[0] += vec2(0.0, MNEE_EPS_UV);
            vec2 Cq = mneeConstraints1(x0, y, sp, lambda);
            vec2 J1 = (Cq - C0) / MNEE_EPS_UV;

            mat2 A = mat2(J0, J1);
            float detJ = A[0][0] * A[1][1] - A[0][1] * A[1][0];
            if (abs(detJ) < 1e-10) {
                return outSolve;
            }

            invAbsDetJ = abs(1.0 / detJ);

            vec2 delta;
            if (!solveLinear2(A, -C0, delta)) {
                return outSolve;
            }

            s.uv[0] += delta;
        }
        else if (s.count == 2u) {
            vec4 C = mneeConstraints2(x0, y, s, lambda);

            if (maxAbsConstraint4(C) < MNEE_EPS_C) {
                mat4 J0 = mneeJacobian2FiniteDiff(x0, y, s, lambda);
                float detJ0 = determinant(J0);
                if (abs(detJ0) < 1e-10) {
                    return outSolve;
                }

                outSolve.ok = true;
                outSolve.invAbsDetJ = abs(1.0 / detJ0);
                outSolve.seed = s;
                return outSolve;
            }

            mat4 J = mneeJacobian2FiniteDiff(x0, y, s, lambda);
            float detJ = determinant(J);
            if (abs(detJ) < 1e-10) {
                return outSolve;
            }

            invAbsDetJ = abs(1.0 / detJ);

            const int MAX_ITERS_2 = 3;
            int refreshCountdown = 0;

            for (int it2 = 0; it2 < MAX_ITERS_2; ++it2) {
                vec4 Cold = C;
                MneeSeed sold = s;

                vec4 Cnew;
                float alphaUsed;
                bool accepted = mneeSolveStep2(x0, y, lambda, C, s, J, Cnew, alphaUsed);
                if (!accepted) {
                    if (refreshCountdown == 0) {
                        J = mneeJacobian2FiniteDiff(x0, y, sold, lambda);
                        float detJr = determinant(J);
                        if (abs(detJr) < 1e-10) {
                            return outSolve;
                        }
                        invAbsDetJ = abs(1.0 / detJr);
                        refreshCountdown = 1;

                        s = sold;
                        C = Cold;
                        continue;
                    }
                    return outSolve;
                }

                C = Cnew;

                if (maxAbsConstraint4(C) < MNEE_EPS_C) {
                    float detJa = determinant(J);
                    if (abs(detJa) > 1e-10) {
                        invAbsDetJ = abs(1.0 / detJa);
                    } else {
                        J = mneeJacobian2FiniteDiff(x0, y, s, lambda);
                        detJa = determinant(J);
                        if (abs(detJa) < 1e-10) {
                            return outSolve;
                        }
                        invAbsDetJ = abs(1.0 / detJa);
                    }

                    outSolve.ok = true;
                    outSolve.invAbsDetJ = invAbsDetJ;
                    outSolve.seed = s;
                    return outSolve;
                }

                vec4 sStep = vec4(
                    s.uv[0].x - sold.uv[0].x,
                    s.uv[0].y - sold.uv[0].y,
                    s.uv[1].x - sold.uv[1].x,
                    s.uv[1].y - sold.uv[1].y
                );
                vec4 yDiff = C - Cold;

                broydenUpdateGood4(J, sStep, yDiff);

                if (alphaUsed < 0.25) {
                    refreshCountdown = 0;
                } else if (refreshCountdown > 0) {
                    refreshCountdown--;
                }

                float detJk = determinant(J);
                if (abs(detJk) > 1e-10) {
                    invAbsDetJ = abs(1.0 / detJk);
                } else {
                    J = mneeJacobian2FiniteDiff(x0, y, s, lambda);
                    detJk = determinant(J);
                    if (abs(detJk) < 1e-10) {
                        return outSolve;
                    }
                    invAbsDetJ = abs(1.0 / detJk);
                }
            }

            if (maxAbsConstraint4(C) < 2.0 * MNEE_EPS_C) {
                float detJf = determinant(J);
                if (abs(detJf) <= 1e-10) {
                    J = mneeJacobian2FiniteDiff(x0, y, s, lambda);
                    detJf = determinant(J);
                    if (abs(detJf) < 1e-10) {
                        return outSolve;
                    }
                }

                outSolve.ok = true;
                outSolve.invAbsDetJ = abs(1.0 / detJf);
                outSolve.seed = s;
                return outSolve;
            }

            return outSolve;
        }
        else {
            float C0[6];
            mneeConstraints3(x0, y, s, lambda, C0);

            float maxC = 0.0;
            for (int k = 0; k < 6; ++k) {
                maxC = max(maxC, abs(C0[k]));
            }
            if (maxC < MNEE_EPS_C) {
                outSolve.ok = true;
                outSolve.invAbsDetJ = invAbsDetJ;
                outSolve.seed = s;
                return outSolve;
            }

            float J[6][6];
            for (int r = 0; r < 6; ++r) {
                for (int c = 0; c < 6; ++c) {
                    J[r][c] = 0.0;
                }
            }

            for (uint col = 0u; col < 6u; ++col) {
                MneeSeed sp = s;
                uint vi = col / 2u;
                uint uvComp = col - 2u * vi;

                if (uvComp == 0u) {
                    sp.uv[vi] += vec2(MNEE_EPS_UV, 0.0);
                } else {
                    sp.uv[vi] += vec2(0.0, MNEE_EPS_UV);
                }

                float Cp[6];
                mneeConstraints3(x0, y, sp, lambda, Cp);

                for (int r = 0; r < 6; ++r) {
                    J[r][int(col)] = (Cp[r] - C0[r]) / MNEE_EPS_UV;
                }
            }

            float b[6];
            for (int r = 0; r < 6; ++r) {
                b[r] = -C0[r];
            }

            float step[6];
            float detJ;
            if (!solveLinear6(J, b, step, detJ) || abs(detJ) < 1e-10) {
                return outSolve;
            }

            invAbsDetJ = abs(1.0 / detJ);

            s.uv[0] += vec2(step[0], step[1]);
            s.uv[1] += vec2(step[2], step[3]);
            s.uv[2] += vec2(step[4], step[5]);
        }
    }

    // final accept
    if (s.count == 1u) {
        vec2 Cf = mneeConstraints1(x0, y, s, lambda);
        if (maxAbsConstraint2(Cf) < 2.0 * MNEE_EPS_C) {
            outSolve.ok = true;
            outSolve.invAbsDetJ = invAbsDetJ;
            outSolve.seed = s;
        }
    }
    else if (s.count == 2u) {
        vec4 Cf = mneeConstraints2(x0, y, s, lambda);
        if (maxAbsConstraint4(Cf) < 2.0 * MNEE_EPS_C) {
            outSolve.ok = true;
            outSolve.invAbsDetJ = invAbsDetJ;
            outSolve.seed = s;
        }
    }
    else {
        float Cf[6];
        mneeConstraints3(x0, y, s, lambda, Cf);
        float maxC = 0.0;
        for (int k = 0; k < 6; ++k) {
            maxC = max(maxC, abs(Cf[k]));
        }
        if (maxC < 2.0 * MNEE_EPS_C) {
            outSolve.ok = true;
            outSolve.invAbsDetJ = invAbsDetJ;
            outSolve.seed = s;
        }
    }

    return outSolve;
}

bool sampleMneeLightPoint(
    vec3 receiverPos,
    vec3 receiverN,
    float lambda,
    inout uint rng,
    out uint seedTriIndex,
    out vec3 seedPos,
    out vec3 seedN,
    out float seedIor,
    out float seedPdfA,
    out uint lightTriIndex,
    out vec3 lightPos,
    out vec3 lightN,
    out float lightPdfA,
    out vec2 seedUv
) {
    uint transmissiveCount = frame.transmissiveTriangleCount.x;
    if (transmissiveCount == 0u || frame.extra.x == 0u) {
        return false;
    }

    if (!sampleTransmissivePoint(
            rng,
            transmissiveCount,
            receiverPos,
            seedTriIndex,
            seedPos,
            seedN,
            seedIor,
            seedPdfA,
            seedUv
        )) {
        return false;
    }

    uint lightSlot = sampleEmissiveTriangle(rand01(rng));
    lightTriIndex = emissiveTriangles[lightSlot].triIndex_pad.x;

    float lightArea = emissiveTriangles[lightSlot].area_pmf_cdf_pad.x;
    float lightPmf  = emissiveTriangles[lightSlot].area_pmf_cdf_pad.y;
    if (lightArea <= 0.0 || lightPmf <= 0.0) {
        return false;
    }

    vec3 a, b, c;
    loadTriangle(lightTriIndex, a, b, c);
    lightN = triangleNormal(a, b, c);

    const float guideMix = 0.9;
    const float sigmaBary = 0.08;

    vec3 bc;
    float pdfGuidedLocal = 0.0;
    bool usedGuided = false;

    vec3 yPred;
    vec3 bcPred;

    if (predictGuidedLightPoint(
            receiverPos,
            receiverN,
            seedPos,
            seedN,
            seedIor,
            true,
            a, b, c,
            yPred) &&
        pointToTriangleBary(yPred, a, b, c, bcPred)) {

        if (rand01(rng) < guideMix) {
            if (sampleTriangleGuidedBary(bcPred, sigmaBary, rng, bc, pdfGuidedLocal)) {
                usedGuided = true;
            }
        }
    }

    if (!usedGuided) {
        vec2 u = sampleUniformTriangle(vec2(rand01(rng), rand01(rng)));
        bc = vec3(1.0 - u.x - u.y, u.x, u.y);
    }

    lightPos = baryToPoint(bc, a, b, c);

    float pdfUniformArea = lightPmf / lightArea;
    float pdfGuidedArea = 0.0;

    if (usedGuided) {
        pdfGuidedArea = lightPmf * pdfGuidedLocal / max(lightArea, 1e-8);
        lightPdfA = guideMix * pdfGuidedArea + (1.0 - guideMix) * pdfUniformArea;
    } else {
        lightPdfA = pdfUniformArea;
    }

    return lightPdfA > 0.0;
}

float mneeAreaLightDirect(
    vec3 x0,
    vec3 n0,
    vec3 V0,
    float lambda,
    float albedoS,
    inout uint rng
) {
    if (frame.extra.x == 0u) return 0.0;
    if (frame.transmissiveTriangleCount.x == 0u) return 0.0;

    uint seedTriIndex;
    vec3 seedPos;
    vec3 seedN;
    float seedIor;
    float seedPdfA;
    vec2 seedUv;

    uint triL;
    vec3 y;
    vec3 lightN;
    float lightPdfA;

    if (!sampleMneeLightPoint(
            x0,
            n0,
            lambda,
            rng,
            seedTriIndex,
            seedPos,
            seedN,
            seedIor,
            seedPdfA,
            triL,
            y,
            lightN,
            lightPdfA,
            seedUv)) {
        return 0.0;
    }

    // Receiver-dependent seed chain
    MneeSeed seed = buildMneeSeed(
        x0, n0, y, lambda, seedTriIndex, seedUv
    );
    bool seedOk = false;
    float seedErr = 1e30;

    if (seed.count == 1u) {
        vec2 C0 = mneeConstraints1(x0, y, seed, lambda);
        seedErr = maxAbsConstraint2(C0);
        seedOk = (seedErr < MNEE_MAX_INITIAL_ERR_1);
    }
    else if (seed.count == 2u) {
        vec4 C0 = mneeConstraints2(x0, y, seed, lambda);
        seedErr = maxAbsConstraint4(C0);
        seedOk = (seedErr < MNEE_MAX_INITIAL_ERR_2);
    }
    else {
        float C0[6];
        mneeConstraints3(x0, y, seed, lambda, C0);
        float maxC = 0.0;
        for (int i = 0; i < 6; ++i) maxC = max(maxC, abs(C0[i]));
        seedErr = maxC;
        seedOk = (seedErr < MNEE_MAX_INITIAL_ERR_3);
    }

    if (!seedOk) {
        return 0.0;
    }

    MneeSolve sol = mneeNewtonsSolve(x0, y, lambda, seed);

    if (!sol.ok) {
        MneeSeed altSeed = seed;
        for (uint i = 0u; i < altSeed.count; ++i) {
            altSeed.tri[i] = quadAlternateIfSameMat(altSeed.tri[i]);
        }
        sol = mneeNewtonsSolve(x0, y, lambda, altSeed);
    }

    if (!sol.ok || sol.invAbsDetJ <= 0.0) {
        return 0.0;
    }

    uint count = sol.seed.count;

    vec3 x[3];
    x[0] = triPointUnclamped(sol.seed.tri[0], sol.seed.uv[0]);
    if (count > 1u) x[1] = triPointUnclamped(sol.seed.tri[1], sol.seed.uv[1]);
    if (count > 2u) x[2] = triPointUnclamped(sol.seed.tri[2], sol.seed.uv[2]);

    float Jmetric = 1.0;
    for (uint i = 0u; i < count; ++i) {
        Jmetric *= triAreaJacobianUv(sol.seed.tri[i]);
    }

    float invAbsDetJCorrect = sol.invAbsDetJ * Jmetric;
    if (invAbsDetJCorrect <= 0.0) {
        return 0.0;
    }

    vec3 xLast = x[count - 1u];

    vec3 dirFirst = normalize(x[0] - x0);

    uint firstHitTri;
    float firstHitT;
    vec2 firstHitUv;
    if (!traceClosestMaxT(
            x0 + n0 * EPS,
            dirFirst,
            INF_T,
            firstHitTri,
            firstHitT,
            firstHitUv)) {
        return 0.0;
    }

    uint wantMat = triangleMaterialIndices[sol.seed.tri[0]];
    uint hitMat  = triangleMaterialIndices[firstHitTri];

    // First segment: only require that the first actual hit belongs
    // to the same material as the solved first spec surface.
    if (hitMat != wantMat) {
        return 0.0;
    }

    // Snap the first manifold vertex to the actual traced hit.
    sol.seed.tri[0] = firstHitTri;
    sol.seed.uv[0]  = firstHitUv;
    x[0] = triPointUnclamped(firstHitTri, firstHitUv);

    for (uint i = 1u; i < count; ++i) {
        if (!segmentHitsExpectedQuad(x[i - 1u], x[i], int(sol.seed.tri[i]))) {
            return 0.0;
        }
    }

    if (!segmentHitsExpectedQuad(xLast, y, int(triL))) {
        return 0.0;
    }

    float Gprod = 1.0;
    vec3 prev = x0;
    vec3 prevN = n0;

    for (uint i = 0u; i < count; ++i) {
        vec3 curr = x[i];
        vec3 d = curr - prev;
        float dist2 = dot(d, d);
        if (dist2 <= 1e-12) return 0.0;

        vec3 wi = normalize(d);
        vec3 currN = triNormalFlat(sol.seed.tri[i]);

        float cosA = abs(dot(prevN, wi));
        float cosB = abs(dot(currN, -wi));

        Gprod *= (cosA * cosB) / max(dist2, 1e-8);

        prev = curr;
        prevN = currN;
    }

    vec3 L0 = normalize(x[0] - x0);
    float NoL0 = max(dot(n0, L0), 0.0);
    if (NoL0 <= 0.0) return 0.0;

    float f0 = albedoS / PI;
    if (f0 <= 0.0) return 0.0;

    float specW = 1.0;
    float etaFrom = 1.0;
    float TrGlass = 1.0;
    bool inGlass = false;
    float sigmaA_glass = 0.0;

    for (uint i = 0u; i < count; ++i) {
        uint triS = sol.seed.tri[i];
        Material matS = materials[triangleMaterialIndices[triS]];
        float etaMat = materialIorAtLambda(triS, lambda);

        vec3 prevP = (i == 0u) ? x0 : x[i - 1u];
        vec3 thisP = x[i];
        vec3 nextP = (i + 1u < count) ? x[i + 1u] : y;

        vec3 wi = normalize(thisP - prevP);
        vec3 n = triNormalFlat(triS);

        float tr = clamp(matS.metallic_smoothShading_transmission_ior.z, 0.0, 1.0);
        float tintS = clamp(rgb_to_reflectance_spectrum(lambda, matS.albedo_smoothness.xyz), 0.0, 1.0);
        float surfTintT = mix(1.0, tintS, tr);
        float surfTintR = mix(1.0, tintS, 0.05 * tr);

        if (sol.seed.evt[i] == EVT_REFLECT) {
            float etaI = etaFrom;
            float etaT = (etaFrom == 1.0) ? etaMat : 1.0;

            if (dot(wi, n) > 0.0) {
                n = -n;
                float tmp = etaI;
                etaI = etaT;
                etaT = tmp;
            }

            vec3 tdir;
            bool hasTransmit = refractDir(wi, n, etaI / etaT, tdir);

            if (!hasTransmit) {
                specW *= surfTintR;
            } else {
                float cosI = abs(dot(-wi, n));
                float F = fresnelDielectric(cosI, etaI, etaT);
                specW *= F * surfTintR;
            }
        } else {
            float etaI = etaFrom;
            float etaT = (etaFrom == 1.0) ? etaMat : 1.0;

            if (dot(wi, n) > 0.0) {
                n = -n;
                float tmp = etaI;
                etaI = etaT;
                etaT = tmp;
            }

            float cosI = abs(dot(-wi, n));
            float F = fresnelDielectric(cosI, etaI, etaT);

            specW *= tr * (1.0 - F);

            float eta2 = (etaI * etaI) / max(etaT * etaT, 1e-8);
            specW *= eta2;

            bool wasAir = (etaFrom == 1.0);
            if (wasAir) {
                inGlass = true;
                sigmaA_glass = -log(max(tintS, MIN_T)) * matS.thinFilmSubstrateK_absorption_pad.y * tr;
            } else {
                inGlass = false;
            }

            etaFrom = etaT;
        }

        if (specW <= 0.0) return 0.0;

        if ((i + 1u) < count && inGlass) {
            float dIn = length(x[i + 1u] - thisP);
            TrGlass *= exp(-sigmaA_glass * dIn);
        }
    }

    TrGlass = max(TrGlass, GLASS_MIN_TRANSMIT);

    vec3 toL = y - xLast;
    float dist2 = dot(toL, toL);
    if (dist2 <= 1e-12) return 0.0;

    vec3 wiL = normalize(toL);
    float cosL = max(dot(lightN, -wiL), 0.0);
    if (cosL <= 0.0) return 0.0;

    uint lightMatIndex = triangleMaterialIndices[triL];
    Material lightMat = materials[lightMatIndex];
    vec3 LeRGB = lightMat.emissive_emissiveIntensity.xyz * lightMat.emissive_emissiveIntensity.w;
    float LeS = rgb_to_emission_spectrum(lambda, LeRGB);
    if (LeS <= 0.0) return 0.0;

    float contrib =
        Gprod *
        LeS *
        f0 *
        NoL0 *
        specW *
        invAbsDetJCorrect *
        TrGlass *
        (cosL / max(dist2, 1e-8)) /
        max(lightPdfA, 1e-12);

    return max(contrib, 0.0);
}

void main() {
    uvec2 pix = gl_GlobalInvocationID.xy;
    uint width = frame.screen.x;
    uint height = frame.screen.y;

    if (pix.x >= width || pix.y >= height) return;

    uint pixelIndex = pix.y * width + pix.x;

    vec2 uv = (vec2(pix) + vec2(0.5)) / vec2(width, height);
    vec2 ndc = uv * 2.0 - 1.0;
    ndc.y = -ndc.y;

    float tanHalfFovY = frame.camData.x;
    float aspect = frame.camData.y;

    vec3 camRo = frame.camPos.xyz;
    vec3 camRd = normalize(
        frame.camForward.xyz +
        ndc.x * aspect * tanHalfFovY * frame.camRight.xyz +
        ndc.y * tanHalfFovY * frame.camUp.xyz
    );

    const uint LAMBDA_SPP = 4u;

    vec3 totalRadianceXYZ = vec3(0.0);

    // Keep some final state for the debug/path buffer write at end.
    float lastThroughput = 1.0;
    float lastLambda = 550.0;
    vec3 lastRadianceXYZ = vec3(0.0);
    vec3 lastRo = camRo;
    vec3 lastRd = camRd;
    uint lastBounce = 0u;

    float prevBsdfPdfW = 0.0;
    float prevNeePdfW  = 0.0;
    bool  prevHadNee   = false;
    bool  prevWasDeltaEvent = true;

    for (uint ls = 0u; ls < LAMBDA_SPP; ++ls) {
        uint rng = pixelIndex * 9781u +
                   frame.screen.w * 6271u +
                   ls * 26699u + 1u;

        vec3 ro = camRo;
        vec3 rd = camRd;

        float uLambda = (float(ls) + rand01(rng)) / float(LAMBDA_SPP);
        float lambda = mix(LAMBDA_MIN, LAMBDA_MAX, uLambda);
        vec3 lambdaXYZ = cie_xyz_bar(lambda) * (LAMBDA_MAX - LAMBDA_MIN);

        float throughput = 1.0;
        vec3 radianceXYZ = vec3(0.0);

        bool pathInsideGlass = false;
        float pathSigmaA = 0.0;

        for (uint bounce = 0u; bounce < frame.extra.w; ++bounce) {
            uint prim = 0u;
            float tHit = INF_T;
            vec2 bary = vec2(0.0);
            bool hitSurface = traceClosest(ro, rd, prim, tHit, bary);

            float sigmaT = (frame.extra.z != 0u) ? max(frame.fogParams.x, 0.0) : 0.0;
            float fogG   = clamp(frame.fogParams.y, -0.99, 0.99);

            if (sigmaT > 0.0) {
                float tScatter = sampleFreeFlight(sigmaT, rng);

                if (tScatter < tHit) {
                    vec3 scatterPos = ro + rd * tScatter;

                    vec3 wo = -rd;

                    // NEE to sun
                    if (frame.extra.y != 0u) {
                        float sunC = mediumSunDirect(scatterPos, wo, lambda, sigmaT, fogG);
                        radianceXYZ += (throughput * sunC) * lambdaXYZ;
                    }

                    // NEE to emissive triangles with MIS against phase sampling
                    if (frame.extra.x != 0u) {
                        float areaC = mediumAreaLightDirect(scatterPos, wo, lambda, sigmaT, fogG, rng);
                        radianceXYZ += (throughput * areaC) * lambdaXYZ;
                    }

                    // Sample phase function for indirect continuation
                    float pdfPhase;
                    vec3 newDir = samplePhaseHG(wo, fogG, vec2(rand01(rng), rand01(rng)), pdfPhase);
                    if (pdfPhase <= 1e-8) {
                        lastBounce = bounce;
                        break;
                    }

                    // Check if the phase-sampled ray immediately hits an emitter or escapes to sun.
                    uint mPrim;
                    float mTHit;
                    vec2 mBary;
                    bool mHit = traceClosest(scatterPos + newDir * MEDIUM_EPS, newDir, mPrim, mTHit, mBary);

                    if (mHit) {
                        float hitLe = mediumPhaseHitEmitter(
                            scatterPos, wo, newDir, mPrim, mTHit, lambda, sigmaT, fogG
                        );
                        if (hitLe > 0.0) {
                            radianceXYZ += (throughput * hitLe) * lambdaXYZ;
                        }
                    } else if (frame.extra.y != 0u) {
                        vec3 sunDir = normalize(frame.sunDirIntensity.xyz);
                        float cosToSun = dot(newDir, sunDir);
                        if (cosToSun > 0.99995) {
                            float pdfSun = 1.0; // delta light not sampled by phase path in measure-consistent way
                            float pdfPhaseHit = phaseHGPdf(dot(wo, newDir), fogG);
                            float wPhase = 1.0; // directional sun handled as pure NEE in this simple implementation
                            float LeS = rgb_to_emission_spectrum(lambda, frame.sunColor.xyz * frame.sunDirIntensity.w);
                            radianceXYZ += (throughput * LeS * wPhase) * lambdaXYZ;
                        }
                    }

                    throughput = min(throughput, 20.0);

                    ro = scatterPos + newDir * MEDIUM_EPS;
                    rd = newDir;

                    lastRo = ro;
                    lastRd = rd;
                    lastThroughput = throughput;
                    lastLambda = lambda;
                    lastRadianceXYZ = radianceXYZ;
                    lastBounce = bounce + 1u;
                    continue;
                }

                // No medium event before surface: apply beam transmittance
                if (tHit < 1e30 && tHit > -1e30) {
                    throughput *= transmittanceHomogeneous(sigmaT, tHit);
                }
            }

            if (!hitSurface) {
                tHit = INF_T;
                if (bounce == 0u) {
                    imageStore(albedoImage, ivec2(pix), vec4(0.0, 0.0, 0.0, 1.0));
                    imageStore(normalImage, ivec2(pix), vec4(0.5, 0.5, 1.0, 1.0));
                    imageStore(depthImage, ivec2(pix), vec4(1e30, 0.0, 0.0, 1.0));
                }
                lastBounce = bounce;
                break;
            } else if (pathInsideGlass) {
                throughput *= exp(-pathSigmaA * tHit);
            }

            vec3 v0, v1, v2;
            loadTriangle(prim, v0, v1, v2);

            uint i0 = indexData[prim * 3u + 0u];
            uint i1 = indexData[prim * 3u + 1u];
            uint i2 = indexData[prim * 3u + 2u];

            vec3 geomN = triangleNormal(v0, v1, v2);
            vec3 hitPos = ro + rd * tHit;
            vec3 V = normalize(-rd);

            uint matIndex = triangleMaterialIndices[prim];
            Material mat = materials[matIndex];

            vec3 albedo = mat.albedo_smoothness.xyz;
            float smoothness = mat.albedo_smoothness.w;
            float metallic = mat.metallic_smoothShading_transmission_ior.x;
            float transmission = mat.metallic_smoothShading_transmission_ior.z;
            float ior = mat.metallic_smoothShading_transmission_ior.w;
            vec3 emissive = mat.emissive_emissiveIntensity.xyz * mat.emissive_emissiveIntensity.w;

            float dispersion = mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.x;

            float albedoS = rgb_to_reflectance_spectrum(lambda, albedo);
            float emissiveS = rgb_to_emission_spectrum(lambda, emissive);
            float iorLambda = iorAtLambda(ior, dispersion, lambda);

            float b1 = bary.x;
            float b2 = bary.y;
            float b0 = 1.0 - b1 - b2;

            vec3 n0 = loadNormal(i0);
            vec3 n1 = loadNormal(i1);
            vec3 n2 = loadNormal(i2);

            float smoothShading = mat.metallic_smoothShading_transmission_ior.y;
            vec3 smoothN = normalize(n0 * b0 + n1 * b1 + n2 * b2);

            bool frontFace = dot(rd, geomN) < 0.0;
            vec3 Ng = frontFace ? geomN : -geomN;

            vec3 rawShadeN = (smoothShading > 0.5) ? smoothN : Ng;
            vec3 Ns = normalize(dot(rawShadeN, Ng) >= 0.0 ? rawShadeN : -rawShadeN);

            // Screen-space caustic lookup on primary diffuse-ish receivers
            if (bounce == 0u && transmission <= 0.001 && metallic < 0.2 && smoothness < 0.3) {
                vec3 causticXYZ = sampleCausticsImageXYZ(ivec2(pix));

                vec3 diffuseRGB = albedo / PI;

                vec3 causticRGB = xyz_to_linear_srgb(causticXYZ);
                causticRGB *= diffuseRGB;

                vec3 causticReflectedXYZ = linear_srgb_to_xyz(causticRGB);

                radianceXYZ += throughput * frame.misc.x * causticReflectedXYZ;
            }

            if (max(emissive.r, max(emissive.g, emissive.b)) > 0.0) {
                float wEmit = 1.0;

                if (bounce > 0u && !prevWasDeltaEvent && prevHadNee) {
                    wEmit = prevBsdfPdfW / max(prevBsdfPdfW + prevNeePdfW, 1e-8);
                }

                radianceXYZ += (throughput * emissiveS * wEmit) * lambdaXYZ;
            }

            // Store to output textures for denoising
            if (bounce == 0u) {
                imageStore(albedoImage, ivec2(pix), vec4(albedo, 1.0));
                imageStore(normalImage, ivec2(pix), vec4(Ns, 1.0));
                imageStore(depthImage, ivec2(pix), vec4(tHit, 0.0, 0.0, 1.0));
            }

            // Area-light NEE
            if (frame.extra.x > 0u) {
                uint lightSlot = sampleEmissiveTriangle(rand01(rng));
                uint lightTriIndex = emissiveTriangles[lightSlot].triIndex_pad.x;
                float lightArea = emissiveTriangles[lightSlot].area_pmf_cdf_pad.x;
                float lightPmf = emissiveTriangles[lightSlot].area_pmf_cdf_pad.y;

                vec3 lv0, lv1, lv2;
                loadTriangle(lightTriIndex, lv0, lv1, lv2);

                vec2 u = vec2(rand01(rng), rand01(rng));
                vec2 b = sampleUniformTriangle(u);
                float w0 = 1.0 - b.x - b.y;
                float w1 = b.x;
                float w2 = b.y;

                vec3 lightPos = w0 * lv0 + w1 * lv1 + w2 * lv2;
                vec3 lightN = triangleNormal(lv0, lv1, lv2);

                uint lightMatIndex = triangleMaterialIndices[lightTriIndex];
                Material lightMat = materials[lightMatIndex];
                vec3 Le = lightMat.emissive_emissiveIntensity.xyz * lightMat.emissive_emissiveIntensity.w;

                vec3 toLight = lightPos - hitPos;
                float dist2 = dot(toLight, toLight);

                if (dist2 > EPS && lightPmf > 0.0 && lightArea > 0.0) {
                    float dist = sqrt(dist2);
                    vec3 L = toLight / dist;

                    float cosLight = max(dot(lightN, -L), 0.0);
                    if (cosLight > 0.0) {
                        vec3 shadowOffsetN = dot(L, Ng) >= 0.0 ? Ng : -Ng;
                        bool occluded = traceShadow(hitPos + shadowOffsetN * EPS, L, dist, lightTriIndex);

                        if (!occluded) {
                            float pdfLight = lightPmf / lightArea;
                            float pdfLightSolidAngle = pdfLight * dist2 / max(cosLight, 1e-8);

                            float LeS = rgb_to_emission_spectrum(lambda, Le);

                            float fS = 0.0;
                            float pdfBsdf = 0.0;
                            float cosTerm = 0.0;
                            bool valid = false;

                            if (transmission > 0.001 && !isDeltaSpecular(smoothness)) {
                                float etaI = frontFace ? 1.0 : iorLambda;
                                float etaT = frontFace ? iorLambda : 1.0;

                                bool isTransmissionMode = false;
                                fS = evalDielectricMicrofacet(Ns, V, L,
                                                             roughnessFromSmoothness(smoothness),
                                                             etaI, etaT,
                                                             isTransmissionMode);
                                pdfBsdf = pdfDielectricMicrofacet(Ns, V, L,
                                                                 roughnessFromSmoothness(smoothness),
                                                                 etaI, etaT);
                                cosTerm = abs(dot(Ns, L));
                                valid = (fS > 0.0 && pdfBsdf > 0.0 && cosTerm > 0.0);
                            } else if (transmission <= 0.001) {
                                float NoL = saturate(dot(Ns, L));
                                if (NoL > 0.0) {
                                    fS = evalBSDFScalar(Ns, V, L, albedoS, smoothness, metallic, mat, lambda);
                                    pdfBsdf = bsdfPdf(Ns, V, L, albedoS, smoothness, metallic, lambda, mat);
                                    cosTerm = NoL;
                                    valid = (fS > 0.0 && pdfBsdf > 0.0);
                                }
                            }

                            if (valid) {
                                float wLight = pdfLightSolidAngle / max(pdfLightSolidAngle + pdfBsdf, 1e-8);
                                float contrib = LeS * fS * cosTerm * wLight / max(pdfLightSolidAngle, 1e-8);
                                radianceXYZ += (throughput * contrib) * lambdaXYZ;
                            }
                        }
                    }
                }
            }

            float rrP = clamp(throughput, 0.05, 0.95);
            if (bounce >= 2u) {
                if (rand01(rng) > rrP) {
                    lastBounce = bounce;
                    break;
                }
                throughput /= rrP;
            }

            vec3 newDir;
            bool wasSpecularEvent = false;

            if (transmission > 0.001) {
                vec3 Nd = Ns;
                DielectricSample ds = sampleDielectricBSDF(Nd, V, frontFace, albedoS, smoothness, iorLambda, rng);

                float absNoL = abs(dot(Nd, ds.dir));
                if (ds.pdf <= 1e-8 || absNoL <= 1e-8 || ds.f <= 1e-8) {
                    lastBounce = bounce;
                    break;
                }

                throughput *= ds.f * absNoL / ds.pdf;

                newDir = normalize(ds.dir);

                if (ds.isTransmission != 0u) {
                    if (frontFace) {
                        pathInsideGlass = true;
                        pathSigmaA = materialAbsorptionSigma(prim, lambda);
                    } else {
                        pathInsideGlass = false;
                        pathSigmaA = 0.0;
                    }
                }
                wasSpecularEvent = (ds.isDelta != 0u);

                prevBsdfPdfW = ds.pdf;
                prevNeePdfW  = 0.0;
                prevHadNee   = false;
                prevWasDeltaEvent = (ds.isDelta != 0u);

                vec3 pushNg = dot(newDir, Ng) >= 0.0 ? Ng : -Ng;
                ro = hitPos + pushNg * EPS + newDir * EPS;
                rd = newDir;
            } else if (isOpaqueDeltaSpecular(transmission, metallic, smoothness)) {
                vec3 R = reflect(-V, Ns);

                float filmThickness = mat.dispersion_thinFilmThickness_thinFilmIor_thinFilmSubstrateEta.y;
                float F;
                if (filmThickness > 0.0) {
                    F = thinFilmReflectanceOpaque(mat, lambda, saturate(dot(Ns, V)));
                } else {
                    float F0 = mix(0.04, albedoS, metallic);
                    F = fresnelSchlickScalar(saturate(dot(Ns, V)), F0);
                }

                throughput *= F;
                wasSpecularEvent = true;

                prevBsdfPdfW = 0.0;
                prevNeePdfW  = 0.0;
                prevHadNee   = false;
                prevWasDeltaEvent = true;

                vec3 pushNg = dot(R, Ng) >= 0.0 ? Ng : -Ng;
                ro = hitPos + pushNg * EPS + R * EPS;
                rd = normalize(R);
            } else {
                vec2 uSelect = vec2(rand01(rng), rand01(rng));
                vec2 uDir    = vec2(rand01(rng), rand01(rng));

                float pdf;
                newDir = sampleBSDF(Ns, V, albedoS, smoothness, metallic, lambda, mat, uSelect, uDir, pdf);

                float NoL = max(dot(Ns, newDir), 0.0);
                if (pdf <= 1e-8 || NoL <= 0.0) {
                    lastBounce = bounce;
                    break;
                }

                float fS = evalBSDFScalar(Ns, V, newDir, albedoS, smoothness, metallic, mat, lambda);
                throughput *= fS * NoL / max(pdf, 1e-8);

                vec3 F0 = mix(vec3(0.04), albedo, metallic);
                float specW = specularSamplingWeight(F0);
                wasSpecularEvent = (metallic > 0.5 || smoothness > 0.95 || specW > 0.5);

                prevBsdfPdfW = pdf;
                prevNeePdfW  = 0.0;
                prevHadNee   = true;
                prevWasDeltaEvent = false;

                vec3 pushNg = dot(newDir, Ng) >= 0.0 ? Ng : -Ng;
                vec3 rayStart = hitPos + pushNg * EPS + newDir * EPS;

                uint nextPrim;
                float nextTHit;
                vec2 nextBary;
                if (traceClosest(rayStart, newDir, nextPrim, nextTHit, nextBary)) {
                    uint nextMatIndex = triangleMaterialIndices[nextPrim];
                    Material nextMat = materials[nextMatIndex];
                    vec3 nextEmissive = nextMat.emissive_emissiveIntensity.xyz *
                                        nextMat.emissive_emissiveIntensity.w;

                    if (max(nextEmissive.r, max(nextEmissive.g, nextEmissive.b)) > 0.0) {
                        prevNeePdfW = lightPdfSolidAngleFromPrevVertex(hitPos, pushNg, newDir, nextPrim);
                    }
                }

                ro = rayStart;
                rd = normalize(newDir);
            }

            lastRo = ro;
            lastRd = rd;
            lastThroughput = throughput;
            lastLambda = lambda;
            lastRadianceXYZ = radianceXYZ;
            lastBounce = bounce + 1u;
        }

        totalRadianceXYZ += radianceXYZ;
    }

    vec3 radianceXYZ = totalRadianceXYZ / float(LAMBDA_SPP);

    paths[pixelIndex].ro = vec4(lastRo, 0.0);
    paths[pixelIndex].rd = vec4(lastRd, 0.0);
    paths[pixelIndex].throughput_lambda = vec4(lastThroughput, lastLambda, 0.0, 0.0);
    paths[pixelIndex].radianceXYZ = vec4(radianceXYZ, 0.0);
    paths[pixelIndex].pixelIndex = pixelIndex;
    paths[pixelIndex].alive = 0u;
    paths[pixelIndex].bounce = lastBounce;

    ivec2 ipix = ivec2(pix);

    vec4 prevAccum = imageLoad(accumImage, ipix);
    float frameIndex = float(frame.screen.w);

    vec3 sampleRGB = xyz_to_linear_srgb(radianceXYZ);
    sampleRGB /= max(frame.whiteBalance.xyz, vec3(1e-6));

    vec3 accumColor = (frame.screen.w == 0u)
        ? clamp_rgb_luma(sampleRGB, RGB_CLAMP)
        : clamp_rgb_luma((prevAccum.xyz * frameIndex + sampleRGB) / (frameIndex + 1.0), RGB_CLAMP);

    imageStore(accumImage, ipix, vec4(accumColor, 1.0));
    imageStore(outImage,   ipix, vec4(sampleRGB, 1.0));
}

